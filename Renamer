-- --- [優化] 支援 Animation 的預覽圖生成器 ---
local function CreateMiniPreview(itemInstance, parentUI)
    local vp = Instance.new("ViewportFrame")
    vp.Size = UDim2.new(0, 36, 0, 36) 
    vp.AnchorPoint = Vector2.new(0, 0.5) 
    vp.Position = UDim2.new(0, 5, 0.5, 0) 
    vp.BackgroundTransparency = 1
    vp.ZIndex = parentUI.ZIndex + 1
    vp.Parent = parentUI

    local worldModel = Instance.new("WorldModel")
    worldModel.Parent = vp

    local cloneToRender = nil
    local isAnimationOnly = itemInstance:IsA("Animation")

    -- 尋找是否有實體物件
    if not isAnimationOnly then
        if itemInstance:IsA("Model") or itemInstance:IsA("BasePart") then
            cloneToRender = itemInstance:Clone()
        else
            local foundModel = itemInstance:FindFirstChildWhichIsA("Model", true) or itemInstance:FindFirstChildWhichIsA("BasePart", true)
            if foundModel then
                cloneToRender = foundModel:Clone()
            else
                -- 如果找不到實體物件，但在 Emotes 分類中，檢查是否含有 Animation 物件
                local anim = itemInstance:FindFirstChildWhichIsA("Animation", true)
                if anim then
                    isAnimationOnly = true
                    itemInstance = anim
                end
            end
        end
    end

    -- 處理只有 Animation 軌道的情形：生成一個假人偶來展現姿勢
    if isAnimationOnly then
        cloneToRender = CreateBasicDummy()
        local hum = cloneToRender:FindFirstChildWhichIsA("Humanoid")
        local animator = hum and (hum:FindFirstChildWhichIsA("Animator") or Instance.new("Animator", hum))
        if animator then
            pcall(function()
                local track = animator:LoadAnimation(itemInstance)
                track:Play()
                track:Sample() -- 提取動作第一影格姿態
                track:Stop()
            end)
        end
    end

    if not cloneToRender then 
        vp:Destroy()
        return 
    end
    cloneToRender.Parent = worldModel

    if cloneToRender:IsA("Model") then
        if not cloneToRender.PrimaryPart then
            cloneToRender.PrimaryPart = cloneToRender:FindFirstChildWhichIsA("BasePart")
        end
        if cloneToRender.PrimaryPart then
            cloneToRender:PivotTo(CFrame.identity)
        end
    elseif cloneToRender:IsA("BasePart") then
        cloneToRender.CFrame = CFrame.identity
    end

    local camera = Instance.new("Camera")
    camera.FieldOfView = 25 
    camera.Parent = vp
    vp.CurrentCamera = camera

    local size = Vector3.new(2, 2, 2)
    if cloneToRender:IsA("Model") then
        local _, bbSize = cloneToRender:GetBoundingBox()
        size = bbSize
    elseif cloneToRender:IsA("BasePart") then
        size = cloneToRender.Size
    end

    local maxDim = math.max(size.X, size.Y, size.Z)
    local dist = maxDim * 1.25
    if dist < 0.4 then dist = 0.4 end
    
    camera.CFrame = CFrame.new(Vector3.new(dist * 0.8, dist * 0.4, dist * 0.8), Vector3.new(0, 0, 0))
end
