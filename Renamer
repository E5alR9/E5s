-- --- [新增功能] 讀取 Module 內部的 AppearanceInfo.Name 顯示名稱 ---
local function GetItemDisplayName(item)
    local success, data = pcall(function()
        if item:IsA("ModuleScript") then
            return require(item)
        else
            local settingsModule = item:FindFirstChildWhichIsA("ModuleScript", true)
            if settingsModule then
                return require(settingsModule)
            end
        end
    end)
    
    if success and type(data) == "table" and data.AppearanceInfo and data.AppearanceInfo.Name then
        return data.AppearanceInfo.Name
    end
    return item.Name -- 如果沒有配置表或讀取失敗，退回使用原本名字
end

-- --- Core Logic ---
local function RefreshLists()
    -- Clear old
    for _, v in pairs(LeftList:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
    for _, v in pairs(RightList:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
    
    LeftSearch.Text = ""
    RightSearch.Text = ""
    
    local folder = CATEGORIES[currentCategory]
    if not folder then return end
    
    local items = folder:GetChildren()
    
    -- 先行收集包含顯示名稱的資料包，方便按照顯示名稱排序
    local itemDataList = {}
    for _, item in ipairs(items) do
        table.insert(itemDataList, {
            Instance = item,
            DisplayName = GetItemDisplayName(item)
        })
    end
    
    table.sort(itemDataList, function(a, b)
        return a.DisplayName < b.DisplayName
    end)
    
    for _, data in ipairs(itemDataList) do
        local item = data.Instance
        local displayName = data.DisplayName
        
        -- Left Option
        local btnL = Instance.new("TextButton")
        btnL.Size = UDim2.new(1, 0, 0, 42) 
        btnL.BackgroundTransparency = 1
        btnL.Text = "" 
        btnL.ZIndex = 22
        btnL.Parent = LeftList
        
        local textL = Instance.new("TextLabel")
        textL.Size = UDim2.new(1, -50, 1, 0)
        textL.Position = UDim2.new(0, 50, 0, 0) 
        textL.BackgroundTransparency = 1
        textL.Text = displayName -- 這裡改成顯示配置名稱 (例如 Broom of Doom)
        textL.TextColor3 = Color3.new(1, 1, 1)
        textL.Font = Enum.Font.GothamMedium
        textL.TextSize = 15
        textL.TextXAlignment = Enum.TextXAlignment.Left 
        textL.ZIndex = 23
        textL.Parent = btnL

        CreateMiniPreview(item, btnL) 
        
        btnL.MouseButton1Click:Connect(function()
            targetItem = item
            targetDisplayName = displayName
            LeftDropBtn.Text = displayName
            LeftContainer.Visible = false
            UpdatePreview() 
        end)
        
        -- Right Option
        local btnR = Instance.new("TextButton")
        btnR.Size = UDim2.new(1, 0, 0, 42) 
        btnR.BackgroundTransparency = 1
        btnR.Text = "" 
        btnR.ZIndex = 22
        btnR.Parent = RightList
        
        local textR = Instance.new("TextLabel")
        textR.Size = UDim2.new(1, -50, 1, 0)
        textR.Position = UDim2.new(0, 50, 0, 0) 
        textR.BackgroundTransparency = 1
        textR.Text = displayName -- 這裡也改成顯示配置名稱
        textR.TextColor3 = Color3.new(1, 1, 1)
        textR.Font = Enum.Font.GothamMedium
        textR.TextSize = 15
        textR.TextXAlignment = Enum.TextXAlignment.Left
        textR.ZIndex = 23
        textR.Parent = btnR
        
        CreateMiniPreview(item, btnR) 
        
        btnR.MouseButton1Click:Connect(function()
            sourceName = item.Name -- 核心替換依然使用檔案系統名稱
            sourceDisplayName = displayName
            RightDropBtn.Text = displayName
            RightContainer.Visible = false
            UpdatePreview() 
        end)
    end
end

-- Switch Tabs
local function SwitchTab(cat)
    currentCategory = cat
    targetItem = nil
    sourceName = nil
    targetDisplayName = nil
    sourceDisplayName = nil
    
    LeftDropBtn.Text = "Select " .. cat
    RightDropBtn.Text = "Select Name"
    
    LeftContainer.Visible = false
    RightContainer.Visible = false
    
    if cat == "Emotes" then
        EmoteTab.BackgroundTransparency = 0.4
        CosmeticTab.BackgroundTransparency = 0.8
    else
        CosmeticTab.BackgroundTransparency = 0.4
        EmoteTab.BackgroundTransparency = 0.8
    end
    
    RefreshLists()
    UpdatePreview() 
end

