-- Function to Update Preview Logic
local function UpdatePreview()
    local targetPart = ""
    if targetItem then
        local name = targetItem.Name
        if string.match(name, "[^%w_]") then
            targetPart = '["' .. name .. '"]'
        else
            targetPart = '.' .. name
        end
    else
        targetPart = "." 
    end

    local sourcePart = '""'
    if sourceName then
        sourcePart = '"' .. sourceName .. '"'
    end

    local code = string.format('game:GetService("ReplicatedStorage").Items.%s%s.Name = %s', 
        currentCategory, 
        targetPart, 
        sourcePart
    )
    PreviewBox.Text = code
end

-- === [NEW] Create List with Search Box ===
local function CreateDropdownList(parentBtn)
    -- Container for Search and List
    local Container = Instance.new("Frame")
    Container.Name = "DropdownContainer"
    Container.Size = UDim2.new(1, 0, 5, 0) -- 高度放大以容納搜尋列
    Container.Position = UDim2.new(0, 0, 1.1, 0)
    Container.BackgroundColor3 = Color3.new(0.05, 0.05, 0.05)
    Container.BackgroundTransparency = 0.1
    Container.BorderSizePixel = 0
    Container.Visible = false
    Container.ZIndex = 20
    Container.Parent = parentBtn
    Instance.new("UICorner", Container).CornerRadius = UDim.new(0, 6)
    
    -- Search Box
    local SearchBox = Instance.new("TextBox")
    SearchBox.Name = "SearchBar"
    SearchBox.Size = UDim2.new(1, -10, 0, 30)
    SearchBox.Position = UDim2.new(0, 5, 0, 5)
    SearchBox.BackgroundColor3 = Color3.new(0, 0, 0)
    SearchBox.BackgroundTransparency = 0.5
    SearchBox.TextColor3 = Color3.new(1, 1, 1)
    SearchBox.PlaceholderText = "Search item..."
    SearchBox.Font = Enum.Font.Gotham
    SearchBox.TextSize = 14
    SearchBox.ClearTextOnFocus = false
    SearchBox.ZIndex = 21
    SearchBox.Parent = Container
    Instance.new("UICorner", SearchBox).CornerRadius = UDim.new(0, 4)

    -- Scrolling Frame
    local Scroll = Instance.new("ScrollingFrame")
    Scroll.Name = "List"
    Scroll.Size = UDim2.new(1, 0, 1, -40)
    Scroll.Position = UDim2.new(0, 0, 0, 40)
    Scroll.BackgroundTransparency = 1
    Scroll.BorderSizePixel = 0
    Scroll.ScrollBarThickness = 4
    Scroll.AutomaticCanvasSize = Enum.AutomaticSize.Y -- 自動適應內容高度
    Scroll.CanvasSize = UDim2.new(0, 0, 0, 0)
    Scroll.ZIndex = 21
    Scroll.Parent = Container
    
    local Layout = Instance.new("UIListLayout")
    Layout.Parent = Scroll
    Layout.SortOrder = Enum.SortOrder.LayoutOrder
    
    -- Search Logic (Filter)
    SearchBox:GetPropertyChangedSignal("Text"):Connect(function()
        local query = string.lower(SearchBox.Text)
        for _, btn in pairs(Scroll:GetChildren()) do
            if btn:IsA("TextButton") then
                if query == "" or string.find(string.lower(btn.Text), query) then
                    btn.Visible = true
                else
                    btn.Visible = false
                end
            end
        end
    end)
    
    return Container, Scroll, SearchBox
end

