-- [[ 0. 宣告 UI 監測與文字替換所需的系統服務與變數 ]]
local Players = game:GetService("Players")
local CoreGui = game:GetService("CoreGui")
local S = game:GetService("ReplicatedStorage"):WaitForChild("Items")

local TARGET_TEXT = "Swag Walk"
local NEW_TEXT    = "Zombie Stride" 

-- [[ 1. 嚴格還原你的 dup 邏輯：先 Clone 備份，再將原物件改名 ]]
local function dup(folder, old, new) 
    local i = folder:FindFirstChild(old) 
    if i then 
        print("//// CLONE //// " .. old .. " ===>>> " .. new)
        -- 先複製一份原封不動的留在資料夾內 (備份)
        i:Clone().Parent = folder 
        -- 將原本的這個物件改名為新名字 (SwagWalk)，確保與其關連的代碼不失效
        i.Name = new 
        return i
    end 
    return nil
end

-- =============================================================
-- 💡 [只在這裡加入]：在執行 dup 之前，將「舊有 SwagWalk」的內容物洗成 ZombieStride
-- =============================================================
local originalSwagWalk = S.Emotes:FindFirstChild("SwagWalk")
local zombieStride = S.Emotes:FindFirstChild("ZombieStride")

if originalSwagWalk and zombieStride then
    print("🔄 發現舊的 SwagWalk，正在將其體內內容物替換為 ZombieStride...")
    -- (1) 先完全清空原本 SwagWalk 裡面的所有舊東西
    for _, child in ipairs(originalSwagWalk:GetChildren()) do
        child:Destroy()
    end
    -- (2) 把 ZombieStride 的所有內容物複製到原本的 SwagWalk 裡面
    for _, child in ipairs(zombieStride:GetChildren()) do
        child:Clone().Parent = originalSwagWalk
    end
    print("✅ 舊的 SwagWalk 內容物已成功洗成 ZombieStride！")
end
-- =============================================================

-- [[ 2. 執行複製流程 ]] （完全不動你原本的這段核心）
local emote = dup(S.Emotes, "ZombieStride", "SwagWalk")

if emote then
    -- 清理新改名後的 SwagWalk
    local oldModule = emote:FindFirstChild("EmoteModuleClassic")
    if oldModule then oldModule:Destroy() end

    -- 確保播放容器 AnimationClassic 存在
    local container = emote:FindFirstChild("AnimationClassic")
    if not container then
        container = Instance.new("Animation")
        container.Name = "AnimationClassic"
        container.Parent = emote
    end

    -- 提取 A, B, C 的動畫 ID
    local anims = {}
    local options = emote:FindFirstChild("PossibleOptionsClassic")
    if options then
        for _, n in ipairs({"A", "B", "C"}) do
            local f = options:FindFirstChild(n)
            local a = f and f:FindFirstChildOfClass("Animation")
            if a then table.insert(anims, a.AnimationId) end
        end
    end

    -- [[ 3. 零延遲絕對同步循環 ]]
    task.spawn(function()
        local interval = 2 -- 每 2 秒換一個動作
        print("High-Precision Sync: Locking ABC to Global Server Time (Zero Delay)")
        
        while true do
            if #anims > 0 then
                -- 關鍵：抓取全伺服器統一的毫秒級時間變數
                local totalTime = workspace:GetServerTimeNow()
                
                -- 使用相同的數學公式，確保所有人計算出的 index 瞬間對齊
                local index = (math.floor(totalTime / interval) % #anims) + 1
                
                -- 更新 ID (僅在變動時才寫入，減少系統負擔)
                if container and container.Parent and container.AnimationId ~= anims[index] then
                    container.AnimationId = anims[index]
                end
            end
            -- 設定為 0 達到最高校準頻率，消除所有微小誤差
            task.wait(0)
        end
    end)
    print("Success: SwagWalk is strictly synced and original backup remains.")
else
    warn("Error: Original ZombieStride not found in Emotes.")
end

-- =============================================================
-- [[ 4. 畫面改名功能：實時監控 UI 全局文字並替換（僅針對 "Swag Walk"） ]]
-- =============================================================
task.spawn(function()
    local player = Players.LocalPlayer
    local playerGui = player:WaitForChild("PlayerGui", 10)
    if not playerGui then return end

    local function monitorTextElement(instance)
        if instance:IsA("TextLabel") or instance:IsA("TextButton") or instance:IsA("TextBox") then
            local isUpdating = false 
            
            local function checkAndSwap()
                if isUpdating then return end
                
                local currentText = instance.Text
                -- 僅精準檢查帶有空格的 "Swag Walk"
                if string.find(currentText, TARGET_TEXT) then
                    isUpdating = true
                    instance.Text = string.gsub(currentText, TARGET_TEXT, NEW_TEXT)
                    isUpdating = false
                end
            end
            
            checkAndSwap()
            instance:GetPropertyChangedSignal("Text"):Connect(checkAndSwap)
        end
    end

    -- 掃描目前畫面上已經存在的 UI (PlayerGui)
    for _, descendant in pairs(playerGui:GetDescendants()) do
        monitorTextElement(descendant)
    end
    -- 監聽未來動態新增的 UI (PlayerGui)
    playerGui.DescendantAdded:Connect(monitorTextElement)

    -- 掃描與監聽系統內建的選單 UI (CoreGui)
    pcall(function()
        for _, descendant in pairs(CoreGui:GetDescendants()) do
            monitorTextElement(descendant)
        end
        CoreGui.DescendantAdded:Connect(monitorTextElement)
    end)
    
    print("👁️ 畫面文字監控已啟動：所有 '" .. TARGET_TEXT .. "' 已在畫面上自動更名為 '" .. NEW_TEXT .. "'")
end)
