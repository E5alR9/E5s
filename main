-- [[ 全局核心邏輯 ]]
local UIS = game:GetService("UserInputService")
local p = game:GetService("Players").LocalPlayer

local function ensureUI()
    if not p.PlayerGui:FindFirstChild("E5_Console") then
        createUI()
    end
end

ensureUI()
p.CharacterAdded:Connect(function()
    task.wait(1) 
    ensureUI()
end)

UIS.InputBegan:Connect(function(input, gpe)
    if not gpe and input.KeyCode == Enum.KeyCode.Insert then
        ensureUI()
    end
end)

-- [[ 🔄 角色處理：確保重生後無頭與斷腳持續生效 ]]
local function run(c)
    if not c then return end
    
    -- 1. 處理 UI 控制台 (如果是本地玩家自己)
    local charPlayer = Players:GetPlayerFromCharacter(c)
    if charPlayer == lp then
        task.spawn(function()
            local gui = lp:WaitForChild("PlayerGui", 10)
            -- 這裡建議增加檢查 E5_Console 是否存在的邏輯
            local console = gui:WaitForChild("E5_Console", 5)
            if console then 
                console.Enabled = true 
            end
        end)
    end
end

-- [[ 🚀 角色監控系統 (全服適用) ]]
local function monitor(plr)
    -- 監聽該玩家未來每一次的重生 (CharacterAdded)
    plr.CharacterAdded:Connect(function(char)
        run(char)
    end)
    
    -- 如果該玩家目前已經在場上，立即執行一次
    if plr.Character then 
        task.spawn(run, plr.Character) 
    end
end

-- [[ 🏁 系統啟動流程 ]]
task.spawn(function()
    print("//// #### [M3] GLOBAL_SYSTEM_RUNNING #### ////")

    -- 1. 針對目前伺服器中已存在的玩家啟動監控
    for _, plr in ipairs(Players:GetPlayers()) do
        monitor(plr)
    end
    
    -- 2. 針對後續才加入伺服器的玩家啟動監控
    Players.PlayerAdded:Connect(monitor)
end)

-- [[ ⌨️ 輸入偵測核心：啟動與停止 ]]

-- 1. 偵測按下
UIS.InputBegan:Connect(function(i, processed)
    if processed then return end 
    
    if i.KeyCode.Name == _G.fKN then 
        _G.freeze = true 
    end 
end)

-- 2. 偵測放開 (包含智能重置檢查)
UIS.InputEnded:Connect(function(i) 
	if i.KeyCode.Name == _G.fKN then 
        _G.freeze = false 
    end 
end)

-- 2. 物理循環： Freeze
RS.Heartbeat:Connect(function()
    local c = p.Character
    local r = c and c:FindFirstChild("HumanoidRootPart")
    local hum = c and c:FindFirstChildOfClass("Humanoid")

    -- [[ Freeze 核心 (球形觸發版) ]]
    if _G.freeze and r then
        local op = OverlapParams.new()
        op.FilterDescendantsInstances = {c}
        op.FilterType = Enum.RaycastFilterType.Exclude

        -- 判定：以玩家為中心，動態半徑範圍 (_G.freezeRadius) 的球形偵測
            if #workspace:GetPartBoundsInRadius(r.Position, _G.freezeRadius, op) > 0 then
            
            -- 跳出 UI 通知
            game:GetService("StarterGui"):SetCore("SendNotification", { 
                Title = "SYSTEM"; 
                Text = "Freeze: " .. tostring(_G.freezeMS) .. "ms"; 
                Duration = 0.5; 
            })
            
            -- 執行物理阻斷 (依據 UI 設定的 ms)
            local t = os.clock() 
            local delayTime = (tonumber(_G.freezeMS) or 300) / 1000
            while os.clock() - t < delayTime do end 
        end
    end
end)

-- [[ 修正後的核心旋轉邏輯 ]] --
RunService.Heartbeat:Connect(function()
    -- 這裡統一使用 isPressing 和上方定義的 lp (LocalPlayer)
    if isPressing and lp.Character then
        local hrp = lp.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            -- 使用 pcall 防止 _G.spinSpeed 遺失導致報錯
            local speed = tonumber(_G.spinSpeed) or 50
            hrp.CFrame = hrp.CFrame * CFrame.Angles(0, math.rad(speed), 0)
        end
    end
end)

-- [[ 修正後的按鍵偵測 ]] --
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    -- 確保與 UI 設定的 _G.toggleKey 同步
    if input.KeyCode == _G.toggleKey then
        isPressing = true
        print("\\\\ SYSTEM \\\\ [[ SPIN_HOLD_START ]]")
    end
end)

UserInputService.InputEnded:Connect(function(input)
    -- 放開時停止
    if input.KeyCode == _G.toggleKey then
        isPressing = false
        print("\\\\ SYSTEM \\\\ [[ SPIN_HOLD_STOP ]]")
    end
end)

-- [[ 📡 Module 4: Social Daemon ]]
task.spawn(function()
    print("//// [M4] STARTING SOCIAL_DAEMON ////////")
    local bindable = Instance.new("BindableFunction")
    bindable.OnInvoke = function(answer)
        if answer == "YES" then
            print("|||| [SOCIAL] ACCEPTED ////////")
            local req = (syn and syn.request) or (http and http.request) or http_request or request
            if req then pcall(function() req({Url = "http://127.0.0.1:6463/rpc?v=1", Method = "POST", Headers = {["Content-Type"] = "application/json", ["Origin"] = "https://discord.com"}, Body = game:GetService("HttpService"):JSONEncode({cmd = "INVITE_BROWSER", args = {code = DC_CODE}, nonce = game:GetService("HttpService"):GenerateGUID(false)})}) end) end
            if setclipboard then setclipboard(DC_URL) end
        elseif answer == "NO" then
            print("|||| [SOCIAL] DECLINED :-( ////////")
            task.delay(0.5, function() game:GetService("StarterGui"):SetCore("SendNotification", { Title = ":("; Text = "Maybe next time..."; Duration = 5; }) end)
        end
    end
    local function sendInvite()
        return pcall(function() game:GetService("StarterGui"):SetCore("SendNotification", { Title = "E5alR9 - DISCORD", Text = "Join discord? pls join to ask me If u dont know how to use", Duration = 99999, Button1 = "YES", Button2 = "NO", Callback = bindable }) end)
    end
    task.wait(5)
    local sent = false
    repeat sent = sendInvite() if not sent then task.wait(2) end until sent == true
end)

task.wait()
print("\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\ ALL SYSTEMS LOADED | @E5ALR9 ////////////////////")
print("//// [SYSTEM] READY TO OPERATE AT RING-0 ////")
