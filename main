            leftKBtn.Text = "DONE"
            leftKBtn.TextColor3 = Color3.new(0.5, 0.5, 0.5)
        else
            leftKBtn.Text = "Left Korblox"
            leftKBtn.TextColor3 = Color3.new(1, 1, 1)
        end
    end
    
