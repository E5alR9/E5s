        if _G.rightKClicked then
            rightKBtn.Text = "DONE"
            rightKBtn.TextColor3 = Color3.new(0.5, 0.5, 0.5)
        else
            rightKBtn.Text = "Right Korblox"
            rightKBtn.TextColor3 = Color3.new(1, 1, 1)
        end

