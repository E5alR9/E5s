	-- [[ 點擊與輸入事件 ]]

    capExBtn.MouseButton1Click:Connect(function()
        -- 1. 獲取文字盒內容並轉換為數字
        local num = tonumber(capBox.Text)
        
        -- 2. 更新全域變數 (即便這次是為了關閉，先更新也無妨，下次開啟就會用到)
        if num then
            _G.JumpCap = num
        end

        -- 3. 官方 SendNotification (告知觸發動作)
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "Jump System",
            Text = "Triggering Toggle...", -- 正在切換狀態
