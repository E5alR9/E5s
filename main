    local function updateOneTimeButtons()
        -- Headless 狀態
        if _G.headlessClicked then
            headlessBtn.Text = "DONE"
            headlessBtn.TextColor3 = Color3.new(0.5, 0.5, 0.5) -- 變灰色
        else
            headlessBtn.Text = "Headless"
            headlessBtn.TextColor3 = Color3.new(1, 1, 1)
        end

