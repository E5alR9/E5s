    local btnH = 35    -- 按鈕高度
    local gapX = 0.02  -- 橫向間隙
    local startY = 35  -- 起始 Y 位置
    local rowGap = 45  -- 每一排的間距 (35 + 10)

    -- 計算 X 位置的函式
    local function getX(col)
        return gapX + (col - 1) * (btnW + gapX)
    end

    -- [[ 第一排 ]]

    -- Zombie (1-1)
    local zbBtn = Instance.new("TextButton", m) 
    zbBtn.Size = UDim2.new(btnW, 0, 0, btnH)
    zbBtn.Position = UDim2.new(getX(1), 0, 0, startY) 
    zbBtn.ZIndex = 10 
    zbBtn.BackgroundColor3 = Color3.new(0, 0, 0) 
    zbBtn.BackgroundTransparency = 0.7 
    zbBtn.Text = "Zombie"
    zbBtn.TextColor3 = Color3.new(1, 1, 1)
    zbBtn.Visible = not _G.isMinimized
    Instance.new("UICorner", zbBtn)

    -- Sky (1-2)
    local skyBtn = Instance.new("TextButton", m)
    skyBtn.Size = UDim2.new(btnW, 0, 0, btnH)
    skyBtn.Position = UDim2.new(getX(2), 0, 0, startY)
    skyBtn.ZIndex = 10
    skyBtn.BackgroundColor3 = Color3.new(0, 0, 0)
    skyBtn.BackgroundTransparency = 0.7
    skyBtn.Text = "Sky"
    skyBtn.TextColor3 = Color3.new(1, 1, 1)
    skyBtn.Visible = not _G.isMinimized
    Instance.new("UICorner", skyBtn)

    -- Bhop (1-3)
    local bhopBtn = Instance.new("TextButton", m)
    bhopBtn.Size = UDim2.new(btnW, 0, 0, btnH)
    bhopBtn.Position = UDim2.new(getX(3), 0, 0, startY)
    bhopBtn.ZIndex = 10
    bhopBtn.BackgroundColor3 = Color3.new(0, 0, 0)
    bhopBtn.BackgroundTransparency = 0.7
    bhopBtn.Text = "Bhop"
    bhopBtn.TextColor3 = Color3.new(1, 1, 1)
    bhopBtn.Visible = not _G.isMinimized
    Instance.new("UICorner", bhopBtn)

    -- Player (1-4)
    local playerBtn = Instance.new("TextButton", m)
    playerBtn.Size = UDim2.new(btnW, 0, 0, btnH)
    playerBtn.Position = UDim2.new(getX(4), 0, 0, startY)
    playerBtn.ZIndex = 10
    playerBtn.BackgroundColor3 = Color3.new(0, 0, 0)
    playerBtn.BackgroundTransparency = 0.7
    playerBtn.Text = "Player"
    playerBtn.TextColor3 = Color3.new(1, 1, 1)
    playerBtn.Visible = not _G.isMinimized
    Instance.new("UICorner", playerBtn)

    -- [[ 第二排 ]]

    -- Edge (2-1)
    local edgeBtn = Instance.new("TextButton", m)
    edgeBtn.Size = UDim2.new(btnW, 0, 0, btnH)
    edgeBtn.Position = UDim2.new(getX(1), 0, 0, startY + rowGap)
    edgeBtn.ZIndex = 10
    edgeBtn.BackgroundColor3 = Color3.new(0, 0, 0)
    edgeBtn.BackgroundTransparency = 0.7
    edgeBtn.Text = "Edge"
    edgeBtn.TextColor3 = Color3.new(1, 1, 1)
    edgeBtn.Visible = not _G.isMinimized
    Instance.new("UICorner", edgeBtn)

    -- Grey Fog (2-2)
    local fogBtn = Instance.new("TextButton", m)
    fogBtn.Size = UDim2.new(btnW, 0, 0, btnH)
    fogBtn.Position = UDim2.new(getX(2), 0, 0, startY + rowGap)
    fogBtn.ZIndex = 10
    fogBtn.BackgroundColor3 = Color3.new(0, 0, 0)
    fogBtn.BackgroundTransparency = 0.7
    fogBtn.Text = "Grey Fog"
    fogBtn.TextColor3 = Color3.new(1, 1, 1)
    fogBtn.Visible = not _G.isMinimized
    Instance.new("UICorner", fogBtn)

    -- Remove (2-3)
    local removeBtn = Instance.new("TextButton", m)
    removeBtn.Size = UDim2.new(btnW, 0, 0, btnH)
    removeBtn.Position = UDim2.new(getX(3), 0, 0, startY + rowGap)
    removeBtn.ZIndex = 10
    removeBtn.BackgroundColor3 = Color3.new(0, 0, 0)
    removeBtn.BackgroundTransparency = 0.7
    removeBtn.Text = "Remove"
    removeBtn.TextColor3 = Color3.new(1, 1, 1)
    removeBtn.Visible = not _G.isMinimized
    Instance.new("UICorner", removeBtn)

    -- Headless (2-4) -> 移到第二排最後一格
    local headlessBtn = Instance.new("TextButton", m)
    headlessBtn.Size = UDim2.new(btnW, 0, 0, btnH)
