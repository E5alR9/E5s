local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local StarterGui = game:GetService("StarterGui")
local VirtualInputManager = game:GetService("VirtualInputManager")
local Camera = workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer

-- 初始化
if getgenv().AutoBlockToggle == nil then getgenv().AutoBlockToggle = false end
getgenv().AutoBlockToggle = not getgenv().AutoBlockToggle
getgenv().HasClicked = false 
getgenv().LastParriedBall = nil -- 【新增】：用來記住剛剛砍了哪顆球

StarterGui:SetCore("SendNotification", {
    Title = "自動格擋 ";
    Text = getgenv().AutoBlockToggle and "狀態：🟢 " or "狀態：🔴 已關閉";
    Duration = 3;
})

if getgenv().AutoBlockConnection then
    getgenv().AutoBlockConnection:Disconnect()
    getgenv().AutoBlockConnection = nil
end

local function clickScreenCenter()
    local viewportSize = Camera.ViewportSize
    local centerX, centerY = viewportSize.X / 2, viewportSize.Y / 2
    
    VirtualInputManager:SendMouseButtonEvent(centerX, centerY, 0, true, game, 0)
    task.delay(0.02, function() 
        VirtualInputManager:SendMouseButtonEvent(centerX, centerY, 0, false, game, 0)
    end)
end

if getgenv().AutoBlockToggle then
    getgenv().AutoBlockConnection = RunService.RenderStepped:Connect(function()
        if not getgenv().AutoBlockToggle then return end 

        local myCharacter = LocalPlayer.Character
        if not myCharacter then return end
        
        local rootPart = myCharacter:FindFirstChild("HumanoidRootPart")
        if not rootPart then return end

        local isAnyBallTargetingMe = false
        local needToClick = false
        local dangerousBall = nil 

        -- 動態組裝雷達陣列
        local targetFolders = {}
        if workspace:FindFirstChild("Balls") then
            table.insert(targetFolders, workspace.Balls)
        end
        if workspace:FindFirstChild("TrainingBalls") then
            table.insert(targetFolders, workspace.TrainingBalls)
        end

        for _, folder in ipairs(targetFolders) do
            for _, ball in ipairs(folder:GetChildren()) do
                if ball:IsA("BasePart") then
                    
                    local targetAttr = ball:GetAttribute("target")
                    if targetAttr == LocalPlayer.Name then
                        isAnyBallTargetingMe = true
                        
                        local distance = (ball.Position - rootPart.Position).Magnitude
                        local velocityVec = ball.AssemblyLinearVelocity
                        local velocityMag = velocityVec.Magnitude 
                        
                        if velocityMag > 0 then
                            local ping = (LocalPlayer:GetNetworkPing() or 0.05) + 0.02 
                            local reactionTime = (velocityMag > 180) and 0.55 or 0.45
                            local dynamicSphereRadius = math.max(velocityMag * (reactionTime + ping), 15)
                            
                            if distance <= dynamicSphereRadius then
                                local directionToMe = (rootPart.Position - ball.Position).Unit
                                local ballDirection = velocityVec.Unit
                                
                                if ballDirection:Dot(directionToMe) > -0.2 then
                                    needToClick = true
                                    dangerousBall = ball 
                                    break 
                                end
                            end
                        end
                    end
                end
            end
            if needToClick then break end 
        end

        -- 【拔刀與鎖定】：砍下去的瞬間，記住我們是為了哪顆球拔刀的
        if needToClick and dangerousBall and not getgenv().HasClicked then
            if dangerousBall:GetAttribute("target") == LocalPlayer.Name then
                getgenv().HasClicked = true 
                getgenv().LastParriedBall = dangerousBall -- 鎖定這顆球！
                clickScreenCenter()
            end
        end

        -- 【多球完美解鎖邏輯】
        if getgenv().LastParriedBall then
            -- 如果我們剛剛砍的那顆球已經消失了，或者它的 Target 已經不再是我
            if not getgenv().LastParriedBall.Parent or getgenv().LastParriedBall:GetAttribute("target") ~= LocalPlayer.Name then
                getgenv().HasClicked = false
                getgenv().LastParriedBall = nil -- 清除記憶，準備迎擊下一顆球
            end
        else
            -- 備用保險：如果場上根本沒球看著我，確保解鎖
            if not isAnyBallTargetingMe then
                getgenv().HasClicked = false
            end
        end
    end)
end
