local StarterGui = game:GetService("StarterGui")
local Workspace = game:GetService("Workspace")
local Players = game:GetService("Players")

-- [ 參數設定 ] --
local MIN_SIZE_TO_DELETE = 200    
local SPECIFIC_PATH = Workspace:FindFirstChild("Game") and Workspace.Game:FindFirstChild("Map") and Workspace.Game.Map:FindFirstChild("InvisParts")

-- 初始化變數
if _G.WallMode == nil then _G.WallMode = 0 end 
if _G.StoredWalls == nil then _G.StoredWalls = {} end

-- 清除舊事件
if _G.AutoDetectConnection then
	_G.AutoDetectConnection:Disconnect()
	_G.AutoDetectConnection = nil
end

-- 切換模式 (0 -> 1 -> 2 -> 3 -> 0)
_G.WallMode = _G.WallMode + 1
if _G.WallMode > 3 then _G.WallMode = 0 end

-- 判斷是否為斜坡 (防止卡死)
local function isSlope(part)
	if part:IsA("WedgePart") or part:IsA("CornerWedgePart") then return true end
	local rotX = math.abs(part.Orientation.X) % 90
	local rotZ = math.abs(part.Orientation.Z) % 90
	if (rotX > 2 and rotX < 88) or (rotZ > 2 and rotZ < 88) then return true end
	return false
end

-- 核心檢查邏輯
local function checkAndRemove(v, forceAll)
	if not v:IsA("BasePart") then return false end
	-- 只要是透明且有碰撞體
	if v.Transparency == 1 and v.CanCollide then
		if isSlope(v) then return false end

		-- 模式 1: 尺寸門檻
		-- 模式 2 & 3: 直接處理 (forceAll = true)
		if forceAll or (math.max(v.Size.X, v.Size.Y, v.Size.Z) >= MIN_SIZE_TO_DELETE) then
			table.insert(_G.StoredWalls, v)
			v.CanCollide = false
			return true
		end
	end
	return false
end

-- 持續偵測
local function startAutoDetection(targetFolder, forceAll)
	local autoDeletedCount = 0
	local source = targetFolder or Workspace
	_G.AutoDetectConnection = source.DescendantAdded:Connect(function(descendant)
		task.delay(0.5, function()
			if descendant and descendant.Parent and checkAndRemove(descendant, forceAll) then
				autoDeletedCount = autoDeletedCount + 1
				pcall(function()
					StarterGui:SetCore("SendNotification", {
						Title = "Auto Detected!";
						Text = "Removed: " .. descendant.Name .. "\n(Total: " .. autoDeletedCount .. ")";
						Duration = 2;
					})
				end)
			end
		end)
	end)
end

-- ==========================================
-- 邏輯執行分流
-- ==========================================

if _G.WallMode == 0 then
    -- [ 模式 0 ] : 恢復
	local restoreCount = 0
	for _, v in pairs(_G.StoredWalls) do
		if v and v.Parent then v.CanCollide = true restoreCount = restoreCount + 1 end
	end
	_G.StoredWalls = {}
	StarterGui:SetCore("SendNotification", {Title = "Restored", Text = "Restored " .. restoreCount .. " parts.", Duration = 3})

elseif _G.WallMode == 1 then
    -- [ 模式 1 ] : 全圖掃描 (大尺寸)
	local deletedCount = 0
	for _, v in pairs(Workspace:GetDescendants()) do
		if checkAndRemove(v, false) then deletedCount = deletedCount + 1 end
	end
	startAutoDetection(Workspace, false)
	StarterGui:SetCore("SendNotification", {Title = "Size Delete", Text = "Deleted " .. deletedCount .. " large walls.", Duration = 3})

elseif _G.WallMode == 2 then
    -- [ 模式 2 ] : 精確刪除 (特定資料夾)
	local deletedCount = 0
	if SPECIFIC_PATH then
		for _, v in pairs(SPECIFIC_PATH:GetChildren()) do
			if checkAndRemove(v, true) then deletedCount = deletedCount + 1 end
		end
		startAutoDetection(SPECIFIC_PATH, true)
		StarterGui:SetCore("SendNotification", {Title = "Specific Clear", Text = "Cleared " .. deletedCount .. " parts in InvisParts.", Duration = 3})
	else
		StarterGui:SetCore("SendNotification", {Title = "Error", Text = "InvisParts path not found!", Duration = 3})
	end

elseif _G.WallMode == 3 then
    -- [ 模式 3 ] : 暴力全刪 (全圖掃描)
	local deletedCount = 0
	for _, v in pairs(Workspace:GetDescendants()) do
		if checkAndRemove(v, true) then deletedCount = deletedCount + 1 end
	end
	startAutoDetection(Workspace, true)
	StarterGui:SetCore("SendNotification", {Title = "Nuclear Option", Text = "Cleared ALL " .. deletedCount .. " hidden walls.", Duration = 3})
end
