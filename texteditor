-- 變數儲存
local foundObjects = {}
local activeTarget = nil 

-- 🔍 搜尋邏輯
searchButton.MouseButton1Click:Connect(function()
    local targetText = searchBox.Text
    if targetText == "" then return end

    -- 清除之前的反藍與清單項目
    for _, data in ipairs(foundObjects) do
        if data.obj.Parent then data.obj.TextColor3 = data.originalColor end
    end
    for _, child in pairs(resultsScroll:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end
    
    foundObjects = {}
    activeTarget = nil
    resultsScroll.CanvasPosition = Vector2.new(0,0)

    local function checkAndStore(obj)
        if obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then
            if obj:IsDescendantOf(screenGui) then return end
            
            local textInObj = string.lower(obj.Text)
            local textToSearch = string.lower(targetText)

            if string.find(textInObj, textToSearch, 1, true) then
                table.insert(foundObjects, { obj = obj, originalColor = obj.TextColor3 })
            end
        end
    end

    for _, obj in pairs(workspace:GetDescendants()) do checkAndStore(obj) end
    for _, obj in pairs(playerGui:GetDescendants()) do checkAndStore(obj) end

    -- 產生右側清單項目
    for _, data in ipairs(foundObjects) do
        -- 建立一個容器 Frame 包裹選取鈕和複製鈕
        local itemFrame = Instance.new("Frame")
        itemFrame.Size = UDim2.new(1, 0, 0, 35)
        itemFrame.BackgroundTransparency = 1
        itemFrame.Parent = resultsScroll

        -- 👆 選取按鈕
        local resBtn = Instance.new("TextButton")
        resBtn.Size = UDim2.new(1, -40, 1, 0)
        resBtn.BackgroundColor3 = Color3.fromRGB(65, 65, 65)
        resBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        resBtn.TextScaled = true
        resBtn.Text = data.obj.Text
        resBtn.Parent = itemFrame

        local btnCorner = Instance.new("UICorner")
        btnCorner.CornerRadius = UDim.new(0, 5)
        btnCorner.Parent = resBtn

        -- 📋 複製路徑按鈕
        local copyBtn = Instance.new("TextButton")
        copyBtn.Size = UDim2.new(0, 35, 1, 0)
        copyBtn.Position = UDim2.new(1, -35, 0, 0)
        copyBtn.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
        copyBtn.Text = "📋"
        copyBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        copyBtn.TextScaled = true
        copyBtn.Parent = itemFrame

        local copyCorner = Instance.new("UICorner")
        copyCorner.CornerRadius = UDim.new(0, 5)
        copyCorner.Parent = copyBtn

        -- 🖱️ 複製按鈕邏輯
        copyBtn.MouseButton1Click:Connect(function()
            local path = data.obj:GetFullName()
            if setclipboard then
                setclipboard(path)
                copyBtn.Text = "✅"
                task.wait(1)
                copyBtn.Text = "📋"
            else
                print("路徑: " .. path)
                copyBtn.Text = "❌" -- 若執行器不支援則顯示 X
            end
        end)

        -- 🖱️ 選取按鈕邏輯
        resBtn.MouseButton1Click:Connect(function()
            if activeTarget and activeTarget.button == resBtn then
                resBtn.BackgroundColor3 = Color3.fromRGB(65, 65, 65)
                if data.obj.Parent then
                    data.obj.TextColor3 = data.originalColor
                end
                replaceBox.Text = ""
                activeTarget = nil
                return 
            end

            for _, child in pairs(resultsScroll:GetChildren()) do
                if child:IsA("Frame") and child:FindFirstChildOfClass("TextButton") then
                    child:FindFirstChildOfClass("TextButton").BackgroundColor3 = Color3.fromRGB(65, 65, 65)
                end
            end
            
            if activeTarget and activeTarget.data.obj.Parent then
                activeTarget.data.obj.TextColor3 = activeTarget.data.originalColor
            end

            resBtn.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
            
            if data.obj.Parent then
                data.obj.TextColor3 = Color3.fromRGB(0, 85, 255)
            end
            
            replaceBox.Text = data.obj.Text
            activeTarget = { data = data, button = resBtn, itemFrame = itemFrame }
        end)
    end
    
    resultsScroll.CanvasSize = UDim2.new(0, 0, 0, #foundObjects * 40 + 10)

    if #foundObjects > 0 then
        replaceBox.Text = foundObjects[1].obj.Text
    else
        replaceBox.Text = ""
    end

    searchButton.Text = "找到了 " .. #foundObjects .. " 個結果！"
    task.wait(2)
    searchButton.Text = "🔍 搜尋並列出結果"
end)

-- ✏️ 替換邏輯
replaceButton.MouseButton1Click:Connect(function()
    local newText = replaceBox.Text
    if #foundObjects == 0 then return end

    if activeTarget then
        if activeTarget.data.obj.Parent then
            activeTarget.data.obj.Text = newText
            activeTarget.data.obj.TextColor3 = activeTarget.data.originalColor
        end
        for i, v in ipairs(foundObjects) do
            if v == activeTarget.data then
                table.remove(foundObjects, i)
                break
            end
        end
        activeTarget.itemFrame:Destroy()
        activeTarget = nil
        replaceButton.Text = "✅ 已替換指定的文字！"
    else
        local count = 0
        for _, data in ipairs(foundObjects) do
            if data.obj.Parent then
                data.obj.Text = newText
                data.obj.TextColor3 = data.originalColor
                count = count + 1
            end
        end
        foundObjects = {}
        for _, child in pairs(resultsScroll:GetChildren()) do
            if child:IsA("Frame") then child:Destroy() end
        end
        replaceButton.Text = "✅ 成功替換 " .. count .. " 個文字！"
    end

    task.wait(1.5)
    replaceButton.Text = "✏️ 替換文字 (沒選則全替換)"
end)

-- UI 拖曳功能
local dragging = false
local dragInput, dragStart, startPos

local function update(input)
    local delta = input.Position - dragStart
    frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end

frame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = frame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then dragging = false end
        end)
    end
end)

frame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then update(input) end
end)
