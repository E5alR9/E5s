local function loadFullMap()
    isUpdating = true
    
    -- 清理舊模型與舊藍光
    for modelName, _ in pairs(generatedTopModels) do
        local existing = Workspace:FindFirstChild(modelName)
        if existing then existing:Destroy() end
    end
    if Workspace:FindFirstChild("TopBlueGlow") then
        Workspace.TopBlueGlow:Destroy()
    end
    generatedTopModels = {}

    local currentBlock = {}
    local count = 0
    for line in (scanData .. "\n"):gmatch("([^\n]*)\n") do
        if line:match("^%[%d+%]") then
            if #currentBlock > 0 then
                local topLevelName = createObject(currentBlock)
                if topLevelName then generatedTopModels[topLevelName] = true end
                count = count + 1
                currentBlock = {}
            end
        end
        if line:match("%S") then table.insert(currentBlock, line) end
    end
    if #currentBlock > 0 then 
        local topLevelName = createObject(currentBlock)
        if topLevelName then generatedTopModels[topLevelName] = true end
        count = count + 1 
    end
    
    -- 🌟 生成獨立的頂部藍光
	-- 🌟 生成獨立的頂部藍光 (實體發光球體 + 往下照的聚光燈)
    local corePoint = Instance.new("Part")
    corePoint.Name = "TopBlueGlow"
    corePoint.Shape = Enum.PartType.Ball
    corePoint.Size = Vector3.new(10, 10, 10) -- 🌟 實體大小，你可以隨意調大讓它更明顯
    corePoint.Position = BLUE_LIGHT_POS
    corePoint.Anchored = true
    corePoint.CanCollide = false
    corePoint.Transparency = 1 -- 🌟 0代表完全可見 (原本是1隱藏)
    corePoint.Material = Enum.Material.Neon -- 🌟 霓虹材質，讓球體本身自帶高亮發光效果
    corePoint.Color = Color3.fromRGB(0, 100, 255) -- 🌟 讓實體球的顏色也是藍色
    corePoint.Parent = Workspace

    local blueLight = Instance.new("PointLight")
    blueLight.Color = Color3.fromRGB(0, 100, 255) -- 濃郁的藍光
    blueLight.Range = 2000 -- 光照範圍，夠大才能照亮周圍
    blueLight.Brightness = 20 -- 光照強度
    blueLight.Shadows = true -- 讓建築能產生影子，看起來更有層次
    blueLight.Parent = corePoint
    
    -- 將藍光容器也加入監控，防刪除
    generatedTopModels["TopBlueGlow"] = true

    print("✅ 光束與頂部藍光已生成！共 " .. count .. " 個物件")
    isUpdating = false
end

