local function createGUI()
    local sg = Instance.new("ScreenGui")
    sg.Name = "LightTweakerGUI"
    local success = pcall(function() sg.Parent = CoreGui end)
    if not success then sg.Parent = Players.LocalPlayer:WaitForChild("PlayerGui") end

    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0, 250, 0, 320)
    frame.Position = UDim2.new(1, -270, 0, 20) 
    frame.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
    frame.BackgroundTransparency = 0.2
    frame.Active = true
    frame.Draggable = true
    frame.Parent = sg

    local title = Instance.new("TextLabel")
    title.Size = UDim2.new(1, 0, 0, 30)
    title.Text = "✨ 體積光束微調 (可拖曳)"
    title.TextColor3 = Color3.new(1, 1, 0.8)
    title.BackgroundColor3 = Color3.fromRGB(60, 60, 80)
    title.Parent = frame

    local layout = Instance.new("UIListLayout")
    layout.Padding = UDim.new(0, 5)
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Parent = frame

    local dummy = Instance.new("Frame")
    dummy.Size = UDim2.new(1, 0, 0, 30)
    dummy.BackgroundTransparency = 1
    dummy.Parent = frame

    local inputs = {}

    local function createInput(name, labelText, defaultVal, order)
        local row = Instance.new("Frame")
        row.Size = UDim2.new(1, 0, 0, 25)
        row.BackgroundTransparency = 1
        row.LayoutOrder = order
        row.Parent = frame

        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(0.5, 0, 1, 0)
        label.Text = labelText
        label.TextColor3 = Color3.new(1, 1, 1)
        label.BackgroundTransparency = 1
        label.TextXAlignment = Enum.TextXAlignment.Right
        label.Parent = row

        local box = Instance.new("TextBox")
        box.Size = UDim2.new(0.4, 0, 1, -4)
        box.Position = UDim2.new(0.55, 0, 0, 2)
        box.Text = tostring(defaultVal)
        box.BackgroundColor3 = Color3.fromRGB(50, 50, 60)
        box.TextColor3 = Color3.new(1, 1, 1)
        box.Parent = row

        inputs[name] = box
    end

    createInput("Scale", "放大倍數:", Config.Scale, 1)
    createInput("HeightOffset", "上下(Y)偏移:", Config.HeightOffset, 2)
    createInput("XOffset", "左右(X)偏移:", Config.XOffset, 3)
    createInput("ZOffset", "前後(Z)偏移:", Config.ZOffset, 4)
    createInput("RotX", "旋轉(X)傾斜:", Config.RotX, 5)
    createInput("RotY", "旋轉(Y)水平:", Config.RotY, 6)
    createInput("RotZ", "旋轉(Z)傾斜:", Config.RotZ, 7)

    local applyBtn = Instance.new("TextButton")
    applyBtn.Size = UDim2.new(0.8, 0, 0, 35)
    applyBtn.Position = UDim2.new(0.1, 0, 0, 0)
    applyBtn.LayoutOrder = 99
    applyBtn.Text = "更新光束 (Apply)"
    applyBtn.BackgroundColor3 = Color3.fromRGB(150, 100, 0)
    applyBtn.TextColor3 = Color3.new(1, 1, 1)
    applyBtn.Font = Enum.Font.SourceSansBold
    applyBtn.TextSize = 18
    applyBtn.Parent = frame

    applyBtn.MouseButton1Click:Connect(function()
        Config.Scale = tonumber(inputs["Scale"].Text) or Config.Scale
        Config.HeightOffset = tonumber(inputs["HeightOffset"].Text) or Config.HeightOffset
        Config.XOffset = tonumber(inputs["XOffset"].Text) or Config.XOffset
        Config.ZOffset = tonumber(inputs["ZOffset"].Text) or Config.ZOffset
        Config.RotX = tonumber(inputs["RotX"].Text) or Config.RotX
        Config.RotY = tonumber(inputs["RotY"].Text) or Config.RotY
        Config.RotZ = tonumber(inputs["RotZ"].Text) or Config.RotZ
        
        print("🔄 正在重新加載光束套用新數值...")
        loadFullMap()
    end)
end

