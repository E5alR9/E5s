-- 2. 監聽與同步 Timer 文字
-- ==========================================
task.spawn(function()
	-- 尋找目標 Timer 物件的輔助函數
	local function getTargetTimer()
		local success, result = pcall(function()
			return PlayerGui.Game.HUD.Overlay.RoundOverlay.RoundTimer.IngameRoundTimer.Timer
		end)
		return success and result or nil
	end

	-- 等待 UI 載入
	local targetTimer = getTargetTimer()
	while not targetTimer and task.wait(0.5) do
		targetTimer = getTargetTimer()
	end

	-- 當找到目標 Timer 時進行同步
	if targetTimer then
		-- 1. 立即同步當前文字
		timerLabel.Text = targetTimer.Text

		-- 2. 綁定事件：只要原版的 Text 一有變化就立刻更新
		targetTimer:GetPropertyChangedSignal("Text"):Connect(function()
			timerLabel.Text = targetTimer.Text
		end)
	end
end)

