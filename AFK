local function loadFullMap()
    local currentBlock = {}
    local count = 0
    for line in (scanData .. "\n"):gmatch("([^\n]*)\n") do
        if line:match("^%[%d+%]") then
            if #currentBlock > 0 then
                local topLevelName = createObject(currentBlock)
                if topLevelName then generatedTopModels[topLevelName] = true end
                count = count + 1
                currentBlock = {}
            end
        end
        if line:match("%S") then table.insert(currentBlock, line) end
    end
    if #currentBlock > 0 then 
        local topLevelName = createObject(currentBlock)
        if topLevelName then generatedTopModels[topLevelName] = true end
        count = count + 1 
    end
    print("✅ 地圖已生成至 (3000, 3000, 3000)！共 " .. count .. " 個物件")
end

