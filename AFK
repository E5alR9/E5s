            local PlayerGui = LocalPlayer:FindFirstChild("PlayerGui")
            local foundVisibleTimer = false
            
            if PlayerGui then
                local gameUI = PlayerGui:FindFirstChild("Game")
                local hud = gameUI and gameUI:FindFirstChild("HUD")
                local overlay = hud and hud:FindFirstChild("Overlay")
                local roundOverlay = overlay and overlay:FindFirstChild("RoundOverlay")
                local roundTimer = roundOverlay and roundOverlay:FindFirstChild("RoundTimer")

                if roundTimer and IsTrulyVisible(roundTimer) then
                    foundVisibleTimer = true
                end
            end

            if foundVisibleTimer then
                task.wait(0.1) 
                if IsFieldClean() then
                    pcall(function() 
                        task.wait(1)
                        ReplicatedStorage.Events.Admin.VIPCommand:FireServer("!time 1")
                    end)
                    task.wait(2)
                end
            else
                task.wait(0.5)
            end
        else
            task.wait(1)
        end
    end
end)

