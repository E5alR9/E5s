local currentRounds = 0
local wasMonsterPresent = false -- 記錄上一刻鬼是否存在

-- 換圖觸發函式
local function TriggerMapChange(rounds)
    pcall(function()
        ReplicatedStorage.Events.Admin.VIPCommand:FireServer("!map WorkFacility")
    end)
    print("[系統提示] 累計回合達 " .. tostring(rounds) .. "，已發送換圖指令：WorkFacility")
end

task.spawn(function()
    print("[系統提示] 鬼實體 (無到有) 獨立計數器已啟動...")
    
    while true do
        local isMonsterPresentNow = not IsFieldClean()

        -- 關鍵判定：【上一刻無鬼】且【這一刻鬼出現】(無到有)
        if not wasMonsterPresent and isMonsterPresentNow then
            currentRounds = currentRounds + 1
            counterLabel.Text = "目前累計回合: " .. currentRounds
            print("[系統提示] 偵測到鬼刷出！回合數 $+1$，當前累計: " .. currentRounds)

            -- 每滿 3 回合觸發換圖
            if currentRounds > 0 and (currentRounds % 3 == 0) then
                task.wait(0.5)
                TriggerMapChange(currentRounds)
            end
        end

        -- 更新狀態供下一次循環對比
        wasMonsterPresent = isMonsterPresentNow

        task.wait(0.5)
    end
end)

