-- UI 可見度檢測函式
local function IsTrulyVisible(element)
    if not element or not element.Visible then return false end
    local current = element.Parent
    while current do
        if current:IsA("ScreenGui") then return current.Enabled
        elseif current:IsA("GuiObject") and not current.Visible then return false end
        current = current.Parent
    end
    return true
end

-- 檢測場上是否乾淨（無鬼）
local function IsFieldClean()
    local playersFolder = workspace:FindFirstChild("Players")
    if not playersFolder then return false end

    local entities = playersFolder:GetChildren()
    for _, entity in pairs(entities) do
        local isActualPlayer = Players:GetPlayerFromCharacter(entity)
        if not isActualPlayer then
            return false 
        end
    end
    return true
end

