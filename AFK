local function startRotation(modelName, anglePerFrame)
    task.spawn(function()
        while true do
            -- 🌟 每一幀動態尋找模型，就算被刪除重置也能馬上抓到新的
            local model = Workspace:FindFirstChild(modelName)
            if model and model.Parent then
                model:PivotTo(model:GetPivot() * CFrame.Angles(0, anglePerFrame, 0))
            end
            task.wait()
        end
    end)
end

