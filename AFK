-- 嚴格檢測 UI 是否真實可見
local function IsTrulyVisible(element)
    if not element.Visible then return false end
    local current = element.Parent
    while current do
        if current:IsA("ScreenGui") then
            return current.Enabled
        elseif current:IsA("GuiObject") then
            if not current.Visible then
                return false
            end
        end
        current = current.Parent
    end
    return true
end

-- 尋找特定計時器
local function IsTimerVisible(timerName)
    local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")
    for _, element in pairs(PlayerGui:GetDescendants()) do
        if element.Name == timerName and element:IsA("GuiObject") then
            if IsTrulyVisible(element) then
                return true
            end
        end
    end
    return false
end

task.spawn(function()
    while true do
        if IsTimerVisible("IntermissionTimer") or IsTimerVisible("RoundTimer") then
            pcall(function()
                ReplicatedStorage.Events.Admin.VIPCommand:InvokeServer("!time 1")
            end)
        
            task.wait(2) 
        else
            -- 沒看到 UI 時，每 0.5 秒檢查一次
            task.wait(0.5)
        end
    end
end)

