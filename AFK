local function getRotationCFrame()
    return CFrame.Angles(
        math.rad(Config.RotX), 
        math.rad(Config.RotY), 
        math.rad(Config.RotZ)
    )
end

local function parseCFrame(str)
    local numbers = {}
    for num in str:gmatch("[%-]?[%d%.eE%+%-]+") do table.insert(numbers, tonumber(num)) end
    if #numbers >= 12 then
        local originalPos = Vector3.new(numbers[1], numbers[2], numbers[3])
        local originalX = Vector3.new(numbers[4], numbers[5], numbers[6])
        local originalY = Vector3.new(numbers[7], numbers[8], numbers[9])
        local originalZ = Vector3.new(numbers[10], numbers[11], numbers[12])
        
        local originalCFrame = CFrame.fromMatrix(originalPos, originalX, originalY, -originalZ)
        
        local scaledPos = originalPos * Config.Scale
        local scaledCFrame = originalCFrame - originalPos + scaledPos
        
        local finalOffset = CUSTOM_ORIGIN + Vector3.new(Config.XOffset, Config.HeightOffset, Config.ZOffset)
        local finalCFrame = getRotationCFrame() * scaledCFrame + finalOffset
        
        return finalCFrame
    end
    return CFrame.new()
end

local function createObject(block)
    local data = {}
    for _, line in ipairs(block) do
        line = line:match("^%s*(.-)%s*$")
        if line == "" or line:match("^%-%-") then continue end
        if line:find("Path:") then data.Path = line:match("Path:%s*(.+)")
        elseif line:find("CFrame:") then data.CFrame = line:match("CFrame:%s*(.+)")
        elseif line:find("Size:") then data.Size = line:match("Size:%s*(.+)")
        elseif line:find("Material:") then data.Material = line:match("Material:%s*(.+)")
        elseif line:find("Color:") then data.Color = line:match("Color:%s*(.+)")
        elseif line:find("MeshId:") then data.MeshId = line:match("MeshId:%s*(.+)")
        elseif line:find("TextureID:") then data.TextureID = line:match("TextureID:%s*(.+)")
        elseif line:find("Transparency:") then data.Transparency = tonumber(line:match("Transparency:%s*(.+)"))
        end
    end
    
    if not data.Path or not data.CFrame then return nil end
    
    local hasMesh = data.MeshId and data.MeshId:find("rbxassetid")
    local part = Instance.new("Part")  
    
    part.Anchored = true
    part.CanCollide = false -- 光束無碰撞
    part.CFrame = parseCFrame(data.CFrame)
    
    if data.Size then
        local sx, sy, sz = data.Size:match("([^,]+),%s*([^,]+),%s*([^,]+)")
        if sx then 
            part.Size = Vector3.new(tonumber(sx) * Config.Scale, tonumber(sy) * Config.Scale, tonumber(sz) * Config.Scale) 
        end
    end
    
    if data.Material and Enum.Material[data.Material] then
        part.Material = Enum.Material[data.Material]
    end
    
    if hasMesh then
        local sm = Instance.new("SpecialMesh")
        sm.MeshType = Enum.MeshType.FileMesh
        sm.MeshId = data.MeshId
        if data.TextureID and data.TextureID ~= "" then
            sm.TextureId = data.TextureID
        end
        sm.Scale = Vector3.new(Config.Scale, Config.Scale, Config.Scale)
        sm.Parent = part
    end
    
    if data.Color then
        local r, g, b = data.Color:match("([^,]+),%s*([^,]+),%s*([^,]+)")
        if r then part.Color = Color3.new(tonumber(r), tonumber(g), tonumber(b)) end
    end
    
    if data.Transparency then 
        part.Transparency = data.Transparency 
    end
    
    local current = Workspace
    local pathParts = {}
    for name in data.Path:gmatch("[^.]+") do table.insert(pathParts, name) end
    if pathParts[1] == "Workspace" then table.remove(pathParts, 1) end
    
    for _, name in ipairs(pathParts) do
        local child = current:FindFirstChild(name)
        if not child then
            child = Instance.new("Model")
            child.Name = name
            child.Parent = current
        end
        current = child
    end
    
    part.Name = data.Path:match("[^.]+$") or "Part"
    part.Parent = current
    
    return pathParts[1]
end

