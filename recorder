-- ======================================================
-- 🛑 [核心修改] 開關邏輯 (再次執行即關閉)
-- ======================================================
if _G.E5_Recorder_Instance then 
    local target = _G.E5_Recorder_Instance:FindFirstChildWhichIsA("CanvasGroup")
    if target then
        TS:Create(target, TweenInfo.new(0.2), {GroupTransparency = 1}):Play()
        local currentPos = target.Position
        local currentSize = target.Size
        local shrinkPos = UDim2.new(currentPos.X.Scale, currentPos.X.Offset + (currentSize.X.Offset / 2), currentPos.Y.Scale, currentPos.Y.Offset)

        local shrink = TS:Create(target, TweenInfo.new(0.4, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
            Size = UDim2.new(0, 0, 0, target.Size.Y.Offset),
            Position = shrinkPos
        })
        
        shrink:Play()
        shrink.Completed:Connect(function()
            if _G.E5_Recorder_Instance then _G.E5_Recorder_Instance:Destroy() end
            _G.E5_Recorder_Instance = nil
        end)
    else
        _G.E5_Recorder_Instance:Destroy()
        _G.E5_Recorder_Instance = nil
    end
    return 
end

