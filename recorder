-- ======================================================
-- 🎮 拖動功能 (Draggable Logic)
-- ======================================================
local dragging, dragInput, dragStart, startPos
mainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = mainFrame.Position
    end
end)
UIS.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement and dragging then
        local delta = input.Position - dragStart
        mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UIS.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
end)

-- ======================================================
-- ⚙️ 核心邏輯
-- ======================================================

-- 錄製
RunService.Heartbeat:Connect(function()
    if isRecording and rootPart then
        table.insert(recordedData, rootPart.CFrame)
        currentFrame = #recordedData
    end
end)

-- 播放/暫停控制
local playbackConn
local function stopPlayback()
    isPlaying = false
    if playbackConn then playbackConn:Disconnect() end
    if rootPart then rootPart.Anchored = false end
    PlayBtn.Text = "PLAY"
    PlayBtn.TextColor3 = Color3.new(1, 1, 1)
end

local function startPlayback()
    if #recordedData == 0 then return end
    
    if currentFrame >= #recordedData then
        currentFrame = 1
    end
    
    isPlaying = true
    rootPart.Anchored = true
    PlayBtn.Text = "PAUSE"
    PlayBtn.TextColor3 = ACCENT_COLOR
    
    playbackConn = RunService.Heartbeat:Connect(function()
        if currentFrame < #recordedData then
            currentFrame = currentFrame + 1
            rootPart.CFrame = recordedData[currentFrame]
        else
            stopPlayback()
        end
    end)
end

-- 按鈕事件
RecBtn.MouseButton1Click:Connect(function()
    if not isRecording then
        stopPlayback()
        recordedData = {}
        currentFrame = 1
        isRecording = true
        RecBtn.Text = "STOP"
        RecBtn.TextColor3 = Color3.new(1, 1, 1)
    else
        isRecording = false
        RecBtn.Text = "RECORD"
        RecBtn.TextColor3 = Color3.fromRGB(255, 80, 80)
    end
end)

PlayBtn.MouseButton1Click:Connect(function()
    if isPlaying then stopPlayback() else startPlayback() end
end)

-- 時間軸拖動
TimeBarBG.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        isDraggingTime = true
        stopPlayback()
    end
end)

RunService.RenderStepped:Connect(function()
    if #recordedData > 0 then
        if isDraggingTime then
            local x = math.clamp((UIS:GetMouseLocation().X - TimeBarBG.AbsolutePosition.X) / TimeBarBG.AbsoluteSize.X, 0, 1)
            currentFrame = math.max(1, math.floor(x * #recordedData))
            rootPart.CFrame = recordedData[currentFrame]
        end
        
        local progress = currentFrame / #recordedData
        TimeBarFill.Size = UDim2.new(progress, 0, 1, 0)
        TimeText.Text = currentFrame .. " / " .. #recordedData .. " Frames"
    end
end)

UIS.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then isDraggingTime = false end
end)

