-- ==========================================
-- 🌵 1. 核心系統：找出目標內最高的 Part
-- ==========================================
local function getHighestPart(targetObj)
    local highestPart = nil
    local maxTopY = -math.huge 

    if targetObj:IsA("BasePart") then
        highestPart = targetObj
        maxTopY = targetObj.Position.Y + (targetObj.Size.Y / 2)
    end

    for _, desc in pairs(targetObj:GetDescendants()) do
        if desc:IsA("BasePart") then
            local topY = desc.Position.Y + (desc.Size.Y / 2)
            if topY > maxTopY then
                maxTopY = topY
                highestPart = desc
            end
        end
    end
    
    return highestPart
end

-- ==========================================
-- 📦 2. 計算 AABB (Axis-Aligned Bounding Box)
-- ==========================================
local function calculateAABB(target)
    local minX, minY, minZ = math.huge, math.huge, math.huge
    local maxX, maxY, maxZ = -math.huge, -math.huge, -math.huge

    local parts = {}
    if target:IsA("BasePart") then table.insert(parts, target) end
    for _, desc in pairs(target:GetDescendants()) do
        if desc:IsA("BasePart") then table.insert(parts, desc) end
    end

    if #parts == 0 then return nil end

    for _, part in ipairs(parts) do
        local cf = part.CFrame
        local size = part.Size / 2
        local corners = {
            cf * Vector3.new(size.X, size.Y, size.Z),
            cf * Vector3.new(-size.X, size.Y, size.Z),
            cf * Vector3.new(size.X, -size.Y, size.Z),
            cf * Vector3.new(-size.X, -size.Y, size.Z),
            cf * Vector3.new(size.X, size.Y, -size.Z),
            cf * Vector3.new(-size.X, size.Y, -size.Z),
            cf * Vector3.new(size.X, -size.Y, -size.Z),
            cf * Vector3.new(-size.X, -size.Y, -size.Z)
        }

        for _, corner in ipairs(corners) do
            minX = math.min(minX, corner.X)
            minY = math.min(minY, corner.Y)
            minZ = math.min(minZ, corner.Z)
            maxX = math.max(maxX, corner.X)
            maxY = math.max(maxY, corner.Y)
            maxZ = math.max(maxZ, corner.Z)
        end
    end

    local aabbSize = Vector3.new(maxX - minX, maxY - minY, maxZ - minZ)
    local aabbCenter = Vector3.new((maxX + minX) / 2, (maxY + minY) / 2, (maxZ + minZ) / 2)
    return aabbCenter, aabbSize
end

-- ==========================================
-- ⚙️ 3. 藍色線框生成與開關系統 (Toggle)
-- ==========================================
local FOLDER_NAME = "AABB_Wireframe_Folder"
local existingFolder = workspace:FindFirstChild(FOLDER_NAME)

if existingFolder then
    -- 🛑 再次執行：刪除資料夾並關閉顯示
    existingFolder:Destroy()
    print("🔴 藍色線框已關閉")
else
    -- 🟢 第一次執行：尋找正確路徑並建立線框
    local gameFolder = workspace:FindFirstChild("Game")
    if not gameFolder then return print("⚠️ 找不到 Game 資料夾") end

    local partsFolder = gameFolder:FindFirstChild("Map") 
        and gameFolder.Map:FindFirstChild("Parts")
        
    if not partsFolder then return print("⚠️ 找不到 Game.Map.Parts 資料夾") end

    local propsFolder = partsFolder:FindFirstChild("ImmovableProps")
    local mapInnerFolder = partsFolder:FindFirstChild("Map") 

    print("🟢 藍色線框已開啟")
    local wireframeFolder = Instance.new("Folder")
    wireframeFolder.Name = FOLDER_NAME
    wireframeFolder.Parent = workspace

    local count = 0

    -- 輔助函數：新增 `expandSize` 參數來決定外框要加大多少
    local function applyWireframe(obj, onlyHighest, expandSize)
        local targetForAABB = obj
        
        if onlyHighest then
            targetForAABB = getHighestPart(obj)
        end
        
        if targetForAABB then
            local center, size = calculateAABB(targetForAABB)

            if center and size then
                -- 如果有傳入擴展值，就把尺寸加上去
                if expandSize then
                    size = size + expandSize
                end

                -- 1. 建立骨架
                local invisibleBox = Instance.new("Part")
                invisibleBox.Name = "AABB_Anchor"
                invisibleBox.Size = size
                invisibleBox.Position = center
                invisibleBox.Anchored = true
                invisibleBox.CanCollide = false
                invisibleBox.Transparency = 1  
                invisibleBox.Parent = wireframeFolder

                -- 2. 畫出線框
                local selectionBox = Instance.new("SelectionBox")
                selectionBox.Adornee = invisibleBox
                selectionBox.Color3 = Color3.fromRGB(0, 170, 255) 
                selectionBox.LineThickness = 0.05                 
                selectionBox.SurfaceTransparency = 1              
                selectionBox.Parent = invisibleBox
                
                count = count + 1
            end
        end
    end

    -- 🎯 目標 1：掃描 ImmovableProps 下的仙人掌 (只框最高點，不放大)
    if propsFolder then
        for _, obj in pairs(propsFolder:GetChildren()) do
            if obj.Name == "Cactus1" or obj.Name == "Cactus2" then
                applyWireframe(obj, true, nil) 
            end
        end
    else
        print("⚠️ 找不到 ImmovableProps 資料夾，跳過仙人掌")
    end

    -- 🎯 目標 2：尋找並處理所有 Bench 下的 Part (全部完整框起來，並加大外框)
    if mapInnerFolder then
        local foundAnyBench = false
        
        -- 設定你要把 Bench 的框放大多少 (X, Y, Z)，數字越大框越寬
        local BENCH_EXPAND_SIZE = Vector3.new(1, 1, 1) 

        -- 掃描 Map 裡面的所有物件，找出所有的 Bench
        for _, obj in pairs(mapInnerFolder:GetChildren()) do
            if obj.Name == "Bench" then
                foundAnyBench = true
                local foundBenchPart = false
                
                -- 把該 Bench 裡面所有的 "Part" 找出來並加上線框，同時傳入加大參數
                for _, child in pairs(obj:GetChildren()) do
                    if child.Name == "Part" then
                        applyWireframe(child, false, BENCH_EXPAND_SIZE) 
                        foundBenchPart = true
                    end
                end
                
                if not foundBenchPart then
                    print("⚠️ 在其中一個 Bench 內找不到名為 'Part' 的物件")
                end
            end
        end
        
        if not foundAnyBench then
            print("⚠️ 在 Map 內找不到任何 'Bench' 物件")
        end
    else
        print("⚠️ 找不到 Parts.Map 資料夾，跳過 Bench")
    end

    print("✅ 成功生成 " .. count .. " 個目標的藍色線框！")
end
