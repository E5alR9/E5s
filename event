local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local player = LocalPlayer

-- ==========================
-- 參數設定
-- ==========================
local DANGER_RADIUS = 40    
local EVADE_DISTANCE = 100  

-- 啟動/關閉開關
if _G.AutoFarmActive then
    _G.AutoFarmActive = false
    print("🔴 已停止：全自動收集")
    return 
end

_G.AutoFarmActive = true
_G.IsBusy = false 
print("🟢 已開啟：極速傳送 (已更新為 workspace.Effects.Tickets 與 workspace.Map 路徑)")

-- ==========================
-- 1. 精準取得資料夾 (優先搜尋直屬 Workspace)
-- ==========================
local function getGameFolders()
    -- 優先對應 workspace.Map 與 workspace.Effects
    local mapFolder = workspace:FindFirstChild("Map") 
                    or (workspace:FindFirstChild("Game") and workspace.Game:FindFirstChild("Map"))
                    
    local effectsFolder = workspace:FindFirstChild("Effects") 
                       or (workspace:FindFirstChild("Game") and workspace.Game:FindFirstChild("Effects"))

    local playersFolder = workspace:FindFirstChild("Players") 
                        or (workspace:FindFirstChild("Game") and workspace.Game:FindFirstChild("Players"))

    return playersFolder, mapFolder, effectsFolder
end

-- ==========================
-- 2. 工具函式
-- ==========================

-- 檢查位置是否在 SafeZone 禁區內 (直接指向 workspace.Map.SafeZones)
local function isInsideForbiddenZone(pos)
    local isForbidden = false
    pcall(function()
        local _, mapFolder, _ = getGameFolders()
        local safeZonesFolder = mapFolder and mapFolder:FindFirstChild("SafeZones")
        
        if safeZonesFolder then
            for _, zone in ipairs(safeZonesFolder:GetChildren()) do
                if zone:IsA("BasePart") then
                    local localPos = zone.CFrame:PointToObjectSpace(pos)
                    if math.abs(localPos.X) <= (zone.Size.X / 2) and
                       math.abs(localPos.Y) <= (zone.Size.Y / 2) and
                       math.abs(localPos.Z) <= (zone.Size.Z / 2) then
                        isForbidden = true
                        break 
                    end
                end
            end
        end
    end)
    return isForbidden
end

local function getObjInfo(item)
    if not item then return nil, nil end
    if item:IsA("BasePart") then
        return item.CFrame, item.Position
    elseif item:IsA("Model") and item.PrimaryPart then
        return item.PrimaryPart.CFrame, item.PrimaryPart.Position
    end
    return nil, nil
end

-- 抓取場上的鬼 (怪物)
local function getActiveAIs(playersFolder)
    local ais = {}
    if playersFolder then
        for _, item in ipairs(playersFolder:GetChildren()) do
            local isRealPlayer = Players:GetPlayerFromCharacter(item)
            if item:FindFirstChild("Hitbox") or (not isRealPlayer and item:FindFirstChild("HumanoidRootPart")) then
                local _, pos = getObjInfo(item)
                if pos then table.insert(ais, pos) end
            end
        end
    end
    return ais
end

local function isSafe(targetPos, ais)
    if not targetPos then return false end
    
    -- 檢查周圍是否有鬼
    for _, aiPos in ipairs(ais) do
        if (targetPos - aiPos).Magnitude < DANGER_RADIUS then
            return false
        end
    end
    
    -- 檢查是否在禁區
    if isInsideForbiddenZone(targetPos) then
        return false
    end
    
    return true
end

local function getNearestAIPos(currentPos, ais)
    local nearestPos = nil
    local minDist = math.huge
    for _, aiPos in ipairs(ais) do
        local dist = (currentPos - aiPos).Magnitude
        if dist < minDist then
            minDist = dist
            nearestPos = aiPos
        end
    end
    return nearestPos
end

local function emergencyEvade(rootPart, currentPos, ais)
    local nearestAIPos = getNearestAIPos(currentPos, ais)
    local direction
    
    if nearestAIPos then
        direction = (currentPos - nearestAIPos).Unit
    else
        direction = CFrame.Angles(0, math.rad(math.random(0, 360)), 0).LookVector
    end
    
    local finalTargetPos = nil
    
    for i = 0, 11 do
        local testRotation = CFrame.Angles(0, math.rad(i * 30), 0)
        local testDirection = (testRotation * direction).Unit
        local testPos = currentPos + (testDirection * EVADE_DISTANCE)
        
        if not isInsideForbiddenZone(testPos) then
            finalTargetPos = testPos
            break
        end
    end
    
    if not finalTargetPos then
        finalTargetPos = currentPos + Vector3.new(0, 100, 0)
    end
    
    local origin = finalTargetPos + Vector3.new(0, 100, 0)
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.FilterDescendantsInstances = {player.Character}
    
    local result = workspace:Raycast(origin, Vector3.new(0, -300, 0), params)
    
    if result and result.Instance.CanCollide then
        rootPart.CFrame = CFrame.new(result.Position + Vector3.new(0, 4, 0))
    else
        rootPart.CFrame = CFrame.new(origin)
    end
    print("⚠️ 執行反向逃脫！")
end

-- ==========================
-- 🏃 3. 主程序：自動收集與防鬼
-- ==========================

local targetAges = {}

task.spawn(function()
    while _G.AutoFarmActive do
        _G.IsBusy = false 
        local character = player.Character
        local rootPart = character and character:FindFirstChild("HumanoidRootPart")
        
        -- 清理過期的物件紀錄
        for t, _ in pairs(targetAges) do
            if not t or not t.Parent then
                targetAges[t] = nil
            end
        end
        
        if rootPart then
            local playersFolder, mapFolder, effectsFolder = getGameFolders()
            
            if playersFolder or effectsFolder then
                local ais = getActiveAIs(playersFolder)
                local myPos = rootPart.Position
                
                -- 【特判】誤入禁區時強制傳送
                if isInsideForbiddenZone(myPos) then
                    _G.IsBusy = true
                    rootPart.CFrame = CFrame.new(3000, 3010, 3000)
                    print("⚠️ 偵測到誤入禁區！已強制傳送至 3000, 3010, 3000")
                    task.wait(1)
                    continue
                end
                
                -- 防鬼檢測
                if not isSafe(myPos, ais) then
                    _G.IsBusy = true 
                    emergencyEvade(rootPart, myPos, ais)
                    task.wait(1) 
                    continue 
                end
                
                -- 搜尋目標 (直接讀取 workspace.Effects.Tickets)
                local allTargets = {}
                local ticketsFolder = effectsFolder and effectsFolder:FindFirstChild("Tickets")
                
                if ticketsFolder then
                    for _, item in ipairs(ticketsFolder:GetChildren()) do
                        table.insert(allTargets, item)
                    end
                end
                
                -- 搜尋可救援對象/其他物品
                if playersFolder then
                    for _, item in ipairs(playersFolder:GetChildren()) do
                        local isRealPlayer = Players:GetPlayerFromCharacter(item)
                        local isAI = item:FindFirstChild("Hitbox")
                        if not isRealPlayer and not isAI then
                            table.insert(allTargets, item)
                        end
                    end
                end
                
                local safeTargets = {}
                
                for _, target in ipairs(allTargets) do
                    if not targetAges[target] then
                        targetAges[target] = os.clock()
                    end
                    
                    local _, targetPos = getObjInfo(target)
                    local isOldEnough = (os.clock() - targetAges[target]) >= 5
                    
                    if targetPos and isSafe(targetPos, ais) and isOldEnough then
                        table.insert(safeTargets, target)
                    end
                end
                
                if #safeTargets > 0 then
                    _G.IsBusy = true 
                    local randomTarget = safeTargets[math.random(1, #safeTargets)]
                    
                    while randomTarget and randomTarget.Parent and _G.AutoFarmActive do
                        local cf, pos = getObjInfo(randomTarget)
                        local currentAIs = getActiveAIs(playersFolder)
                        if not cf or not isSafe(rootPart.Position, currentAIs) then
                            break 
                        end
                        rootPart.CFrame = cf
                        task.wait()
                    end
                end
            end
        else
            task.wait(1)
        end
        task.wait() 
    end
end)
