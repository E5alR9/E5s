local Workspace = game:GetService("Workspace")
local Players = game:GetService("Players")

-- ==========================================
-- 🧊 LoadMap 加載器 (無網格 + 強制 SmoothPlastic)
-- ==========================================
local function LoadMap_SmoothPlastic(scanData)
    local LocalPlayer = Players.LocalPlayer
    local Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local RootPart = Character:WaitForChild("HumanoidRootPart")
    
    -- 以玩家為中心
    local playerOrigin = RootPart.CFrame * CFrame.new(0, 0, -5)
    
    local count = 0
    local generatedModels = {}
    local firstObjCFrame = nil

    local function parseCFrame(str)
        local numbers = {}
        for num in str:gmatch("[%-]?[%d%.eE%+%-]+") do table.insert(numbers, tonumber(num)) end
        if #numbers >= 12 then
            local pos = Vector3.new(numbers[1], numbers[2], numbers[3])
            local x = Vector3.new(numbers[4], numbers[5], numbers[6])
            local y = Vector3.new(numbers[7], numbers[8], numbers[9])
            local z = Vector3.new(numbers[10], numbers[11], numbers[12])
            return CFrame.fromMatrix(pos, x, y, -z)
        end
        return CFrame.new()
    end

    local function createObject(block)
        local data = {}
        for _, line in ipairs(block) do
            line = line:match("^%s*(.-)%s*$")
            if line == "" or line:match("^%-%-") then continue end
            if line:find("Path:") then data.Path = line:match("Path:%s*(.+)")
            elseif line:find("CFrame:") then data.CFrame = line:match("CFrame:%s*(.+)")
            elseif line:find("Size:") then data.Size = line:match("Size:%s*(.+)")
            elseif line:find("Color:") then data.Color = line:match("Color:%s*(.+)")
            elseif line:find("Transparency:") then data.Transparency = tonumber(line:match("Transparency:%s*(.+)"))
            -- 🚨 這裡已經不再抓取 Material 了，因為我們要強制覆寫！
            end
        end
        
        if not data.Path or not data.CFrame then return nil end
        
        local part = Instance.new("Part")  
        part.Anchored = true
        
        -- 🌟 【強制設定為 SmoothPlastic】 🌟
        part.Material = Enum.Material.SmoothPlastic
        
        -- 【座標處理】
        local originalCFrame = parseCFrame(data.CFrame)
        if not firstObjCFrame then firstObjCFrame = originalCFrame end
        local relativeCFrame = firstObjCFrame:ToObjectSpace(originalCFrame)
        part.CFrame = playerOrigin * relativeCFrame
        
        -- 【基礎屬性還原】
        if data.Size then
            local sx, sy, sz = data.Size:match("([^,]+),%s*([^,]+),%s*([^,]+)")
            if sx then part.Size = Vector3.new(tonumber(sx), tonumber(sy), tonumber(sz)) end
        end
        
        if data.Color then
            local r, g, b = data.Color:match("([^,]+),%s*([^,]+),%s*([^,]+)")
            if r then part.Color = Color3.new(tonumber(r), tonumber(g), tonumber(b)) end
        end
        
        if data.Transparency then 
            part.Transparency = data.Transparency 
        end
        
        -- 【建立資料夾與路徑】
        local current = Workspace
        local pathParts = {}
        for name in data.Path:gmatch("[^.]+") do table.insert(pathParts, name) end
        if pathParts[1] == "Workspace" then table.remove(pathParts, 1) end
        
        for _, name in ipairs(pathParts) do
            local child = current:FindFirstChild(name)
            if not child then
                child = Instance.new("Model")
                child.Name = name
                child.Parent = current
            end
            current = child
        end
        
        part.Name = data.Path:match("[^.]+$") or "Part"
        part.Parent = current
        
        return pathParts[1]
    end

    local currentBlock = {}
    for line in (scanData .. "\n"):gmatch("([^\n]*)\n") do
        if line:match("^%[%d+%]") then
            if #currentBlock > 0 then
                local topLevelName = createObject(currentBlock)
                if topLevelName then generatedModels[topLevelName] = true end
                count = count + 1
                currentBlock = {}
            end
        end
        if line:match("%S") then table.insert(currentBlock, line) end
    end
    if #currentBlock > 0 then 
        local topLevelName = createObject(currentBlock)
        if topLevelName then generatedModels[topLevelName] = true end
        count = count + 1 
    end

    print("✅ 加載完畢！共生成 " .. count .. " 個 SmoothPlastic 材質的方塊。")
    return generatedModels
end

