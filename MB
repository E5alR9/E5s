-- [ CapCut Style Ghosting Blur ] --

local RunService = game:GetService("RunService")
local Lighting = game:GetService("Lighting")
local Camera = workspace.CurrentCamera

-- 初始化狀態
_G.GhostingActive = not _G.GhostingActive

-- 清除舊連接
if _G.GhostingConn then
    _G.GhostingConn:Disconnect()
    _G.GhostingConn = nil
end

-- 建立/清理效果組
local function getBlur(name)
    local b = Lighting:FindFirstChild(name) or Instance.new("BlurEffect")
    b.Name = name
    b.Parent = Lighting
    b.Enabled = _G.GhostingActive
    return b
end

local blurMain = getBlur("GB_Main")
local blurTrail = getBlur("GB_Trail")

if _G.GhostingActive then
    local lastCFrame = Camera.CFrame
    
    _G.GhostingConn = RunService.RenderStepped:Connect(function(dt)
        local currentCFrame = Camera.CFrame
        
        -- 計算旋轉速度 (角速度)
        local dot = currentCFrame.LookVector:Dot(lastCFrame.LookVector)
        local angDist = math.acos(math.clamp(dot, -1, 1))
        local speed = angDist / dt
        
        -- CapCut 重影核心邏輯：
        -- Main 負責即時模糊，Trail 負責模擬視覺殘留
        blurMain.Size = math.clamp(speed * 0.2, 0, 25)
        blurTrail.Size = math.clamp(speed * 0.5, 0, 56) -- 較大的數值產生重疊感
        
        -- 模擬重影的「淡出」延遲感
        lastCFrame = lastCFrame:Lerp(currentCFrame, 0.2) -- 這裡的 0.2 決定重影的長度
    end)
    
    print("CapCut 重影效果：已開啟")
else
    blurMain.Enabled = false
    blurTrail.Enabled = false
    print("CapCut 重影效果：已關閉")
end
