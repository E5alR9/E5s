-- [ 3D 實體殘影 (視角優化版：只掃描面前 + 不擋 UI + 開關切換) ] --

local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local StarterGui = game:GetService("StarterGui")
local Camera = workspace.CurrentCamera

-- 設定參數
local FRAME_DELAY = 1.5    -- 殘影延遲 (幀數)
local GHOST_COUNT = 3    -- 殘影層數
local SCAN_RADIUS = 50   -- 掃描半徑 (視角過濾開啟後，半徑可以稍微調大一點)

-- [ 功能 1：系統通知 ]
local function sendNotify(title, text)
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = title,
            Text = text,
            Duration = 3
        })
    end)
end

-- [ 功能 2：開關切換 ]
if _G.Ghost3DActive == nil then _G.Ghost3DActive = false end
_G.Ghost3DActive = not _G.Ghost3DActive

-- [ 功能 3：清理函式 ]
local function cleanup()
    if _G.Ghost3DConn then 
        _G.Ghost3DConn:Disconnect() 
        _G.Ghost3DConn = nil 
    end
    if _G.GhostFolder then 
        _G.GhostFolder:Destroy() 
        _G.GhostFolder = nil 
    end
end

cleanup() 

if _G.Ghost3DActive then
    local ghostFolder = Instance.new("Folder")
    ghostFolder.Name = "ActiveGhosts_FOV_Optimized"
    ghostFolder.Parent = workspace
    _G.GhostFolder = ghostFolder

    local cframeHistory = {}
    local ghostModels = {}

    for i = 1, GHOST_COUNT do
        local model = Instance.new("Model")
        model.Name = "Layer_" .. i
        model.Parent = ghostFolder
        ghostModels[i] = model
    end

    -- [ 核心優化 1：空氣牆過濾 ]
    local function isInvalid(part)
        if part.Transparency >= 0.9 then return true end
        local name = part.Name:lower()
        if name:find("clip") or name:find("collision") or name:find("invisible") or name:find("airwall") then
            return true
        end
        for _, p in ipairs(Players:GetPlayers()) do
            if p.Character and part:IsDescendantOf(p.Character) then return true end
        end
        return false
    end

    -- [ 核心優化 2：視角檢查 ]
    local function isInFront(part)
        local _, onScreen = Camera:WorldToViewportPoint(part.Position)
        return onScreen -- 只有在螢幕範圍內的零件才回傳 true
    end

    local function getVisibleParts()
        local parts = {}
        local found = workspace:GetPartBoundsInRadius(Camera.CFrame.Position, SCAN_RADIUS)
        for _, part in ipairs(found) do
            if part:IsA("BasePart") and not part:IsDescendantOf(ghostFolder) then
                -- 必須同時滿足：不是空氣牆 且 在視角內
                if not isInvalid(part) and isInFront(part) then
                    table.insert(parts, part)
                end
            end
        end
        return parts
    end

    _G.Ghost3DConn = RunService.RenderStepped:Connect(function()
        table.insert(cframeHistory, 1, Camera.CFrame)
        if #cframeHistory > (GHOST_COUNT * FRAME_DELAY) + 1 then
            table.remove(cframeHistory)
        end

        local visibleParts = getVisibleParts()
        
        for i = 1, GHOST_COUNT do
            local layer = ghostModels[i]
            layer:ClearAllChildren()
            
            local historyIndex = i * FRAME_DELAY
            local pastCFrame = cframeHistory[historyIndex]
            
            if pastCFrame then
                local rel = pastCFrame:Inverse() * Camera.CFrame
                
                for _, part in ipairs(visibleParts) do
                    local clone = Instance.new("Part")
                    clone.Size = part.Size
                    clone.Color = part.Color
                    clone.Material = Enum.Material.SmoothPlastic
                    clone.CanCollide = false
                    clone.CanQuery = false
                    clone.CanTouch = false
                    clone.CastShadow = false
                    clone.Anchored = true
                    clone.Transparency = 0.6 + (i * 0.1)
                    
                    clone.CFrame = Camera.CFrame * rel:Inverse() * (Camera.CFrame:Inverse() * part.CFrame)
                    clone.Parent = layer
                end
            end
        end
    end)
    
    sendNotify("3D 殘影系統", "開啟：僅加載視野內物件")
else
    sendNotify("3D 殘影系統", "關閉：殘影已完全清除")
end
