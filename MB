-- [ 真·動態模糊開關 (Camera Motion Blur) ] --

local RunService = game:GetService("RunService")
local Lighting = game:GetService("Lighting")
local Camera = workspace.CurrentCamera

-- 初始化狀態
if _G.DynamicBlurConn == nil then
    _G.MotionBlurActive = false
end

-- 切換開關
_G.MotionBlurActive = not _G.MotionBlurActive

-- 清除舊的連接，避免重複執行導致卡頓
if _G.DynamicBlurConn then
    _G.DynamicBlurConn:Disconnect()
    _G.DynamicBlurConn = nil
end

if _G.MotionBlurActive then
    -- 建立模糊物件
    local blur = Lighting:FindFirstChild("DynamicMotionBlur") or Instance.new("BlurEffect")
    blur.Name = "DynamicMotionBlur"
    blur.Size = 0
    blur.Parent = Lighting
    blur.Enabled = true

    local lastCFrame = Camera.CFrame

    -- 每幀計算轉動速度
    _G.DynamicBlurConn = RunService.RenderStepped:Connect(function()
        local currentCFrame = Camera.CFrame
        -- 計算兩幀之間的角度變化 (角速度)
        local angDist = math.acos(math.clamp(currentCFrame.LookVector:Dot(lastCFrame.LookVector), -1, 1))
        local speed = angDist * (1 / task.wait()) -- 轉向速度

        -- 根據速度調整模糊強度 (0.15 是靈敏度，50 是最大模糊上限)
        blur.Size = math.min(speed * 0.15, 50)
        
        lastCFrame = currentCFrame
    end)
    
    print("真·動態模糊：已開啟")
else
    -- 關閉邏輯
    local blur = Lighting:FindFirstChild("DynamicMotionBlur")
    if blur then blur.Enabled = false end
    print("真·動態模糊：已關閉")
end
