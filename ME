local function syncUIWithPart()
    updateIndividualHighlights()
    
    if #selectedParts == 0 then
        StatusLabel.Text = " Selected: None"
        PathBox.Text = " Path: None"
        return
    elseif #selectedParts == 1 then
        local p = selectedParts[1]
        StatusLabel.Text = " Selected: " .. p.Name
        PathBox.Text = " Path: " .. getObjectPath(p)
        
        sliderUpdaters.PosX(p.Position.X)
        sliderUpdaters.PosY(p.Position.Y)
        sliderUpdaters.PosZ(p.Position.Z)
        sliderUpdaters.SizeX(p.Size.X)
        sliderUpdaters.SizeY(p.Size.Y)
        sliderUpdaters.SizeZ(p.Size.Z)
        
        local rx, ry, rz = p.CFrame:ToEulerAnglesXYZ()
        sliderUpdaters.RotX(math.deg(rx))
        sliderUpdaters.RotY(math.deg(ry))
        sliderUpdaters.RotZ(math.deg(rz))
        
        ColBtn.Text = "CanCollide: " .. tostring(p.CanCollide)
        AnchorBtn.Text = "Anchored: " .. tostring(p.Anchored)
    else
        StatusLabel.Text = " Selected: Multiple (" .. #selectedParts .. ")"
        PathBox.Text = " Path: [Multiple Objects]"
        
        -- 多選時，將 Slider 顯示為總包圍盒的中心與大小
        local center, size = getGroupAABB(selectedParts)
        sliderUpdaters.PosX(center.X)
        sliderUpdaters.PosY(center.Y)
        sliderUpdaters.PosZ(center.Z)
        sliderUpdaters.SizeX(size.X)
        sliderUpdaters.SizeY(size.Y)
        sliderUpdaters.SizeZ(size.Z)
        sliderUpdaters.RotX(0)
        sliderUpdaters.RotY(0)
        sliderUpdaters.RotZ(0)
        
        ColBtn.Text = "CanCollide: Mixed"
        AnchorBtn.Text = "Anchored: Mixed"
    end
end

ToggleSelectBtn.MouseButton1Click:Connect(function()
    isSelecting = not isSelecting
    ToggleSelectBtn.Text = "Click to Select: " .. (isSelecting and "ON" or "OFF")
    ToggleSelectBtn.TextColor3 = isSelecting and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 255, 255)
end)

local mouseClickConn
mouseClickConn = mouse.Button1Down:Connect(function()
    if not ScreenGui.Parent then mouseClickConn:Disconnect() return end
    if isSelecting and mouse.Target and mouse.Target:IsA("BasePart") and mouse.Target ~= boundingPart then
        local target = mouse.Target
        local index = table.find(selectedParts, target)
        
        -- 核心：如果有找到就移除（反選），沒有就加入（多選）
        if index then
            table.remove(selectedParts, index)
        else
            table.insert(selectedParts, target)
        end
        syncUIWithPart()
    end
end)

CopyBtn.MouseButton1Click:Connect(function()
    if #selectedParts > 0 then
        for _, p in ipairs(clipboardParts) do p:Destroy() end
        clipboardParts = {}
        for _, p in ipairs(selectedParts) do
            table.insert(clipboardParts, p:Clone())
        end
        CopyBtn.Text = "Copied ("..#clipboardParts..")!"
        task.delay(1, function() if CopyBtn then CopyBtn.Text = "Copy Selected" end end)
    end
end)

PasteBtn.MouseButton1Click:Connect(function()
    if #clipboardParts > 0 then
        selectedParts = {} -- 貼上時自動選取新貼上的物件
        for _, p in ipairs(clipboardParts) do
            local newPart = p:Clone()
            newPart.Parent = workspace
            newPart.CFrame = p.CFrame
            table.insert(selectedParts, newPart)
        end
        syncUIWithPart()
        PasteBtn.Text = "Pasted!"
        task.delay(1, function() if PasteBtn then PasteBtn.Text = "Paste" end end)
    end
end)

SpawnBtn.MouseButton1Click:Connect(function()
    local newPart = Instance.new("Part")
    newPart.Size = Vector3.new(4, 1, 4)
    newPart.Position = player.Character and player.Character.PrimaryPart and player.Character.PrimaryPart.Position + Vector3.new(0, 5, 0) or Vector3.new(0, 10, 0)
    newPart.Parent = workspace
    
    selectedParts = {newPart} -- 生成時直接替換選取
    syncUIWithPart()
end)

ColBtn.MouseButton1Click:Connect(function()
    if #selectedParts > 0 then
        -- 統一設為第一顆物件的相反狀態
        local newState = not selectedParts[1].CanCollide
        for _, p in ipairs(selectedParts) do p.CanCollide = newState end
        ColBtn.Text = "CanCollide: " .. tostring(newState)
    end
end)

AnchorBtn.MouseButton1Click:Connect(function()
    if #selectedParts > 0 then
        local newState = not selectedParts[1].Anchored
        for _, p in ipairs(selectedParts) do p.Anchored = newState end
        AnchorBtn.Text = "Anchored: " .. tostring(newState)
    end
end)

local function deleteSelectedPart()
    if #selectedParts > 0 then
        for _, p in ipairs(selectedParts) do
            if p and p.Parent then p:Destroy() end
        end
        selectedParts = {}
        syncUIWithPart()
        SelectBox.Visible = false
        dimX.Enabled = false
        dimY.Enabled = false
        dimZ.Enabled = false
    end
end

DestroyBtn.MouseButton1Click:Connect(deleteSelectedPart)

local inputBeganConn
inputBeganConn = UIS.InputBegan:Connect(function(input, gameProcessed)
    if not ScreenGui.Parent then inputBeganConn:Disconnect() return end
    if gameProcessed then return end 
    if input.KeyCode == Enum.KeyCode.Delete or input.KeyCode == Enum.KeyCode.Backspace then
        deleteSelectedPart()
    end
end)

