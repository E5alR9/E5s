local SpawnBtn = createActionButton("Spawn Part", pageTool)
local ColBtn = createActionButton("CanCollide", pageTool)
local AnchorBtn = createActionButton("Anchored", pageTool) 
local DestroyBtn = createActionButton("Destroy Selected", pageTool)
DestroyBtn.BackgroundColor3 = Color3.fromRGB(120, 40, 40) 

switchPage("Tools")

local function syncUIWithPart()
    if not selectedPart then return end
    StatusLabel.Text = " Selected: " .. selectedPart.Name
    PathBox.Text = " Path: " .. getObjectPath(selectedPart)
    
    sliderUpdaters.PosX(selectedPart.Position.X)
    sliderUpdaters.PosY(selectedPart.Position.Y)
    sliderUpdaters.PosZ(selectedPart.Position.Z)
    sliderUpdaters.SizeX(selectedPart.Size.X)
    sliderUpdaters.SizeY(selectedPart.Size.Y)
    sliderUpdaters.SizeZ(selectedPart.Size.Z)
    
    local rx, ry, rz = selectedPart.CFrame:ToEulerAnglesXYZ()
    sliderUpdaters.RotX(math.deg(rx))
    sliderUpdaters.RotY(math.deg(ry))
    sliderUpdaters.RotZ(math.deg(rz))
    
    ColBtn.Text = "CanCollide: " .. tostring(selectedPart.CanCollide)
    AnchorBtn.Text = "Anchored: " .. tostring(selectedPart.Anchored)
end

ToggleSelectBtn.MouseButton1Click:Connect(function()
    isSelecting = not isSelecting
    ToggleSelectBtn.Text = "Click to Select: " .. (isSelecting and "ON" or "OFF")
    ToggleSelectBtn.TextColor3 = isSelecting and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 255, 255)
end)

local mouseClickConn
mouseClickConn = mouse.Button1Down:Connect(function()
    if not ScreenGui.Parent then mouseClickConn:Disconnect() return end
    if isSelecting and mouse.Target and mouse.Target:IsA("BasePart") and mouse.Target ~= boundingPart then
        selectedPart = mouse.Target
        syncUIWithPart()
    end
end)

CopyBtn.MouseButton1Click:Connect(function()
    if selectedPart then
        if clipboardPart then clipboardPart:Destroy() end
        clipboardPart = selectedPart:Clone()
        CopyBtn.Text = "Copied!"
        task.delay(1, function() if CopyBtn then CopyBtn.Text = "Copy Selected" end end)
    end
end)

PasteBtn.MouseButton1Click:Connect(function()
    if clipboardPart then
        local newPart = clipboardPart:Clone()
        newPart.Parent = workspace
        newPart.CFrame = clipboardPart.CFrame
        selectedPart = newPart
        syncUIWithPart()
        PasteBtn.Text = "Pasted!"
        task.delay(1, function() if PasteBtn then PasteBtn.Text = "Paste" end end)
    end
end)

SpawnBtn.MouseButton1Click:Connect(function()
    local newPart = Instance.new("Part")
    newPart.Size = Vector3.new(4, 1, 4)
    newPart.Position = player.Character and player.Character.PrimaryPart and player.Character.PrimaryPart.Position + Vector3.new(0, 5, 0) or Vector3.new(0, 10, 0)
    newPart.Parent = workspace
    selectedPart = newPart
    syncUIWithPart()
end)

ColBtn.MouseButton1Click:Connect(function()
    if selectedPart then
        selectedPart.CanCollide = not selectedPart.CanCollide
        ColBtn.Text = "CanCollide: " .. tostring(selectedPart.CanCollide)
    end
end)

AnchorBtn.MouseButton1Click:Connect(function()
    if selectedPart then
        selectedPart.Anchored = not selectedPart.Anchored
        AnchorBtn.Text = "Anchored: " .. tostring(selectedPart.Anchored)
    end
end)

local function deleteSelectedPart()
    if selectedPart then
        selectedPart:Destroy()
        selectedPart = nil
        StatusLabel.Text = " Selected: None"
        PathBox.Text = " Path: None (Select to copy)"
        ColBtn.Text = "CanCollide"
        AnchorBtn.Text = "Anchored"
        SelectBox.Visible = false
        dimX.Enabled = false
        dimY.Enabled = false
        dimZ.Enabled = false
    end
end

DestroyBtn.MouseButton1Click:Connect(deleteSelectedPart)

local inputBeganConn
inputBeganConn = UIS.InputBegan:Connect(function(input, gameProcessed)
    if not ScreenGui.Parent then inputBeganConn:Disconnect() return end
    if gameProcessed then return end 
    if input.KeyCode == Enum.KeyCode.Delete or input.KeyCode == Enum.KeyCode.Backspace then
        deleteSelectedPart()
    end
end)

