-- 計算多個物件的群組 AABB 包圍盒
local function getGroupAABB(parts)
    if #parts == 0 then return Vector3.zero, Vector3.zero end
    local minX, minY, minZ = math.huge, math.huge, math.huge
    local maxX, maxY, maxZ = -math.huge, -math.huge, -math.huge
    
    for _, part in ipairs(parts) do
        local cf = part.CFrame
        local size = part.Size
        local sx, sy, sz = size.X/2, size.Y/2, size.Z/2
        local corners = {
            cf * Vector3.new(sx, sy, sz), cf * Vector3.new(-sx, sy, sz),
            cf * Vector3.new(sx, -sy, sz), cf * Vector3.new(-sx, -sy, sz),
            cf * Vector3.new(sx, sy, -sz), cf * Vector3.new(-sx, sy, -sz),
            cf * Vector3.new(sx, -sy, -sz), cf * Vector3.new(-sx, -sy, -sz)
        }
        for i = 1, 8 do
            local c = corners[i]
            if c.X < minX then minX = c.X elseif c.X > maxX then maxX = c.X end
            if c.Y < minY then minY = c.Y elseif c.Y > maxY then maxY = c.Y end
            if c.Z < minZ then minZ = c.Z elseif c.Z > maxZ then maxZ = c.Z end
        end
    end
    
    local center = Vector3.new((minX + maxX)/2, (minY + maxY)/2, (minZ + maxZ)/2)
    local boxSize = Vector3.new(maxX - minX, maxY - minY, maxZ - minZ)
    return center, boxSize
end

-- 渲染 AABB 尺寸線
local renderConn
renderConn = RunService.RenderStepped:Connect(function()
    if not ScreenGui.Parent then
        renderConn:Disconnect()
        return
    end
    
    -- 過濾掉被外部刪除的物件
    local validParts = {}
    for _, p in ipairs(selectedParts) do
        if p and p.Parent then table.insert(validParts, p) end
    end
    if #validParts ~= #selectedParts then
        selectedParts = validParts
    end

    if #selectedParts > 0 then
        local center, boxSize = getGroupAABB(selectedParts)
        boundingPart.CFrame = CFrame.new(center)
        boundingPart.Size = boxSize
        SelectBox.Visible = true
        local camPos = camera.CFrame.Position
        local minP, maxP = center - boxSize/2, center + boxSize/2
        local padding = 0.5 
        local cX = (camPos.X > center.X) and maxP.X or minP.X
        local cY = (camPos.Y > center.Y) and maxP.Y or minP.Y
        local cZ = (camPos.Z > center.Z) and maxP.Z or minP.Z
        local tX = math.clamp(camPos.X, minP.X, maxP.X)
        local tY = math.clamp(camPos.Y, minP.Y, maxP.Y)
        local tZ = math.clamp(camPos.Z, minP.Z, maxP.Z)
        
        local off_xY = (cY == maxP.Y) and padding or -padding
        local off_xZ = (cZ == maxP.Z) and padding or -padding
        local off_yX = (cX == maxP.X) and padding or -padding
        local off_yZ = (cZ == maxP.Z) and padding or -padding
        local off_zX = (cX == maxP.X) and padding or -padding
        local off_zY = (cY == maxP.Y) and padding or -padding
        
        dimX.Adornee = boundingPart
        dimX.StudsOffsetWorldSpace = Vector3.new(tX, cY + off_xY, cZ + off_xZ) - center
        txtX.Text = string.format("X: %.1f", boxSize.X)
        dimX.Enabled = true
        
        dimY.Adornee = boundingPart
        dimY.StudsOffsetWorldSpace = Vector3.new(cX + off_yX, tY, cZ + off_yZ) - center
        txtY.Text = string.format("Y: %.1f", boxSize.Y)
        dimY.Enabled = true
        
        dimZ.Adornee = boundingPart
        dimZ.StudsOffsetWorldSpace = Vector3.new(cX + off_zX, cY + off_zY, tZ) - center
        txtZ.Text = string.format("Z: %.1f", boxSize.Z)
        dimZ.Enabled = true
    else
        SelectBox.Visible = false
        dimX.Enabled = false
        dimY.Enabled = false
        dimZ.Enabled = false
    end
end)

local function getObjectPath(obj)
    if not obj then return "None" end
    local path = obj.Name
    local current = obj.Parent
    while current and current ~= game do
        path = current.Name .. "." .. path
        current = current.Parent
    end
    return path
end

