local function createSlider(name, minLimit, maxLimit, valKey, callback, parentPage)
    local fineTuneRange = 50 
    local container = Instance.new("Frame", parentPage)
    container.Size = UDim2.new(1, -20, 0, 40)
    container.BackgroundTransparency = 1

    local label = Instance.new("TextLabel", container)
    label.Size = UDim2.new(0.2, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.TextColor3 = Color3.fromRGB(200, 200, 200)
    label.Text = name
    label.Font = Enum.Font.Code
    label.TextSize = 16
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.ZIndex = 4

    local box = Instance.new("TextBox", container)
    box.Size = UDim2.new(0.2, 0, 0.8, 0)
    box.Position = UDim2.new(0.2, 0, 0.1, 0)
    box.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    box.BackgroundTransparency = 0.4
    box.TextColor3 = Color3.fromRGB(255, 255, 255)
    box.Text = "0"
    box.Font = Enum.Font.Code
    box.TextSize = 16
    box.ClearTextOnFocus = false
    box.ZIndex = 4

    local track = Instance.new("TextButton", container)
    track.Size = UDim2.new(0.55, 0, 0.4, 0)
    track.Position = UDim2.new(0.42, 0, 0.3, 0)
    track.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    track.BackgroundTransparency = 0.4
    track.Text = ""
    track.AutoButtonColor = false
    track.ZIndex = 4

    local centerLine = Instance.new("Frame", track)
    centerLine.Size = UDim2.new(0, 2, 1, 0)
    centerLine.Position = UDim2.new(0.5, -1, 0, 0)
    centerLine.BackgroundColor3 = Color3.fromRGB(120, 120, 120)
    centerLine.BorderSizePixel = 0
    centerLine.ZIndex = 5

    local knob = Instance.new("Frame", track)
    knob.Size = UDim2.new(0, 14, 1.4, 0)
    knob.Position = UDim2.new(0.5, -7, -0.2, 0)
    knob.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
    knob.BorderSizePixel = 0
    knob.ZIndex = 6

    local draggingSlider, baseValue = false, 0
    local function updateTextBox(val)
        val = math.clamp(val, minLimit, maxLimit)
        box.Text = string.format("%.1f", val)
        return val
    end
    local function resetKnob()
        knob.Position = UDim2.new(0.5, -7, -0.2, 0)
        knob.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
    end

    track.MouseButton1Down:Connect(function() 
        draggingSlider = true 
        baseValue = currentValues[valKey] or 0
        knob.BackgroundColor3 = Color3.fromRGB(100, 200, 255) 
    end)

    local inputEndConn
    inputEndConn = UIS.InputEnded:Connect(function(input)
        if not ScreenGui.Parent then inputEndConn:Disconnect() return end
        if input.UserInputType == Enum.UserInputType.MouseButton1 and draggingSlider then
            draggingSlider = false 
            resetKnob() 
        end
    end)

    local inputChangedConn
    inputChangedConn = UIS.InputChanged:Connect(function(input)
        if not ScreenGui.Parent then inputChangedConn:Disconnect() return end
        if draggingSlider and input.UserInputType == Enum.UserInputType.MouseMovement then
            local pct = math.clamp((mouse.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
            knob.Position = UDim2.new(pct, -7, -0.2, 0)
            local offset = (pct - 0.5) * (fineTuneRange * 2) 
            local newVal = math.clamp(baseValue + offset, minLimit, maxLimit)
            updateTextBox(newVal)
            currentValues[valKey] = newVal
            if callback then callback() end
        end
    end)

    box.FocusLost:Connect(function()
        local num = tonumber(box.Text)
        if num then
            local val = math.clamp(num, minLimit, maxLimit)
            updateTextBox(val)
            currentValues[valKey] = val
            if callback then callback() end
        else
            updateTextBox(currentValues[valKey])
        end
    end)

    sliderUpdaters[valKey] = function(newVal)
        currentValues[valKey] = newVal
        updateTextBox(newVal)
        if not draggingSlider then resetKnob() end
    end
end

local function applyTransform()
    if not selectedPart then return end
    selectedPart.CFrame = CFrame.new(currentValues.PosX, currentValues.PosY, currentValues.PosZ) 
                        * CFrame.Angles(math.rad(currentValues.RotX), math.rad(currentValues.RotY), math.rad(currentValues.RotZ))
end
local function applySize()
    if not selectedPart then return end
    selectedPart.Size = Vector3.new(currentValues.SizeX, currentValues.SizeY, currentValues.SizeZ)
end

