local function applyTransform()
    for _, part in ipairs(selectedParts) do
        if part and part.Parent then
            part.CFrame = CFrame.new(currentValues.PosX, currentValues.PosY, currentValues.PosZ) 
                        * CFrame.Angles(math.rad(currentValues.RotX), math.rad(currentValues.RotY), math.rad(currentValues.RotZ))
        end
    end
end
local function applySize()
    for _, part in ipairs(selectedParts) do
        if part and part.Parent then
            part.Size = Vector3.new(currentValues.SizeX, currentValues.SizeY, currentValues.SizeZ)
        end
    end
end

