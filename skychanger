-- 確保 skyIdBox 已經被建立後才讀取
        local num = skyIdBox and tonumber(skyIdBox.Text)
        
        -- 💡 這裡修正了！將輸入的數字正確存入 _G.skyid
        if num then
            _G.skyid = num
        end

        -- 執行替換天空盒的腳本
        pcall(function() 
            local Lighting = game:GetService("Lighting")

            if not _G.skyid then
                warn("錯誤：_G.skyid 尚未設定！")
                return
            end

            -- 處理 ID 格式 (確保帶有 rbxassetid:// 前綴)
            local skyIdStr = tostring(_G.skyid)
            if not string.match(skyIdStr, "^rbxassetid://") then
                skyIdStr = "rbxassetid://" .. skyIdStr
            end

            -- 尋找 Lighting 中現有的 Sky 物件
            local sky = Lighting:FindFirstChildOfClass("Sky")

            -- 如果找不到現有的 Sky 物件，就建立一個新的
            if not sky then
                sky = Instance.new("Sky")
                sky.Name = "CustomSkybox"
                sky.Parent = Lighting
            end

            -- 替換天空盒的 6 個面的 ID
            sky.SkyboxBk = skyIdStr -- 後
            sky.SkyboxDn = skyIdStr -- 下
            sky.SkyboxFt = skyIdStr -- 前
            sky.SkyboxLf = skyIdStr -- 左
            sky.SkyboxRt = skyIdStr -- 右
            sky.SkyboxUp = skyIdStr -- 上
        end)
        
        -- 如果玩家輸入錯誤格式，點擊按鈕時幫他恢復成有效數字
        if not num and skyIdBox then
            skyIdBox.Text = tostring(_G.skyid)
        end
